      expect((await env.db.getSendingMessages('conv_001')).length, 1);
      await env.db.deleteSendingMessage('ms');
      expect(await env.db.getSendingMessages('conv_001'), isEmpty);
      await destroyEnv(env.db, env.dir);
    });

    test('searchMessages', () async {
      final env = await createDbEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      await env.db.insertMessage({
        'clientMsgID': 's1',
        'sendID': 'u1',
        'recvID': 'u2',
        'contentType': 101,
        'sessionType': 1,
        'seq': 1,
        'sendTime': t,
        'status': 2,
        'content': '你好世界',
      });
      await env.db.insertMessage({
        'clientMsgID': 's2',
        'sendID': 'u1',
        'recvID': 'u2',
        'contentType': 101,
        'sessionType': 1,
        'seq': 2,
        'sendTime': t + 1,
        'status': 2,
        'content': '再见世界',
      });
      final results = await env.db.searchMessages(keyword: '世界');
      expect(results.length, 2);
      await destroyEnv(env.db, env.dir);
    });
  });

  // ── 1.10 DB 静态工具 ──
  group('DB-工具方法', () {
    test('safeDecodeJson / safeEncodeJson', () {
      expect(DatabaseService.safeDecodeJson(null), isNull);
      expect(DatabaseService.safeDecodeJson(''), isNull);
      expect(DatabaseService.safeDecodeJson('bad'), isNull);
      final map = {'key': 'value'};
      final encoded = DatabaseService.safeEncodeJson(map);
      expect(encoded, isNotNull);
      expect(DatabaseService.safeDecodeJson(encoded!)!['key'], 'value');
      expect(DatabaseService.safeEncodeJson(null), isNull);
    });
  });

