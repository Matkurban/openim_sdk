        await env.db.insertOrUpdateUser({'userID': 'user_$i', 'nickname': 'nick_$i'});
      }
      final users = await env.db.getUsersByIDs(['user_0', 'user_2', 'user_4']);
      expect(users.length, 3);
      await destroyEnv(env.db, env.dir);
    });

    test('查不到的 ID 返回空', () async {
      final env = await createDbEnv();
      final users = await env.db.getUsersByIDs(['nonexistent']);
      expect(users, isEmpty);
      await destroyEnv(env.db, env.dir);
