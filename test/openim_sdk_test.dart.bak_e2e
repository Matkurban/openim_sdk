    test('simpleSort 置顶优先+时间排序', () {
      final convs = [
        ConversationInfo(conversationID: 'c1', latestMsgSendTime: 100),
        ConversationInfo(conversationID: 'c2', latestMsgSendTime: 300, isPinned: true),
        ConversationInfo(conversationID: 'c3', latestMsgSendTime: 200),
      ];
      final sorted = ConversationManager().simpleSort(convs);
      expect(sorted.first.conversationID, 'c2');
      expect(sorted[1].conversationID, 'c3');
      expect(sorted.last.conversationID, 'c1');
