    test('SEQ 缺口检测', () async {
      final env = await createSyncerEnv();
      final convID = 'si_gap';
      final t = DateTime.now().millisecondsSinceEpoch;
      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'g1',
                  sendID: 'u2',
                  recvID: 'test_user_001',
                  seq: 5,
                  sendTime: t,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 1));
      var gapDetected = false;
      final sub = Logger('MsgSyncer').onRecord.listen((rec) {
        if (rec.message.contains('SEQ 缺口')) gapDetected = true;
      });
      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'g2',
                  sendID: 'u2',
                  recvID: 'test_user_001',
                  seq: 20,
                  sendTime: t + 5000,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 2));
      sub.cancel();
      expect(gapDetected, isTrue);
      await destroyEnv(env.db, env.dir);
    });

    test('多会话并行推送', () async {
      final env = await createSyncerEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            'si_conv_a': {
              'msgs': [
                makeMsg(
                  clientMsgID: 'a1',
                  sendID: 'ua',
                  recvID: 'test_user_001',
                  seq: 1,
                  sendTime: t,
                ),
              ],
            },
            'si_conv_b': {
              'msgs': [
                makeMsg(
                  clientMsgID: 'b1',
                  sendID: 'ub',
                  recvID: 'test_user_001',
                  seq: 1,
                  sendTime: t,
                ),
                makeMsg(
                  clientMsgID: 'b2',
                  sendID: 'ub',
                  recvID: 'test_user_001',
                  seq: 2,
                  sendTime: t + 1000,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 2));
      final convA = await env.db.getConversation('si_conv_a');
      final convB = await env.db.getConversation('si_conv_b');
      expect(convA!['unreadCount'], 1);
      expect(convB!['unreadCount'], 2);
      await destroyEnv(env.db, env.dir);
    });
  });

  // =========================================================================
  //  第五部分：WS 消息格式验证
  // =========================================================================
  group('WS 消息格式', () {
    test('GeneralWsResp 构造和解析', () {
      final testData = utf8.encode(jsonEncode({'key': 'value'}));
      final resp = GeneralWsResp(
        reqIdentifier: 2001,
        errCode: 0,
        errMsg: '',
        msgIncr: 'incr',
        operationID: 'op',
        data: testData,
      );
      expect(resp.reqIdentifier, 2001);
      final decoded = jsonDecode(utf8.decode(resp.data)) as Map<String, dynamic>;
      expect(decoded['key'], 'value');
    });

    test('推送消息结构正确性', () {
      final payload = {
        'msgs': {
          'si_u1_u2': {
            'msgs': [
              {'clientMsgID': 'a', 'seq': 1},
            ],
          },
        },
        'notificationMsgs': {},
      };
      final decoded = jsonDecode(jsonEncode(payload)) as Map<String, dynamic>;
      expect(decoded['msgs'], isNotNull);
      expect(decoded['notificationMsgs'], isNotNull);
    });
  });

  // =========================================================================
  //  第六部分：集成测试 — 真实服务器（两用户互发消息）
  // =========================================================================
  group('集成-真实服务器', () {
    setUp(() async {
      if (GetIt.instance.isRegistered<InitConfig>()) {
        await GetIt.instance.reset();
      }
    });

    tearDown(() async {
      try {
        await OpenIM.iMManager.logout();
      } catch (_) {}
      try {
        await GetIt.instance.reset();
      } catch (_) {}
    });

    test('用户1 登录并同步会话', () async {
      final sync = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () => print('[连接] 成功'),
          onConnectFailed: (c, m) => print('[连接] 失败: $c $m'),
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync.isCompleted) sync.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync.isCompleted) sync.complete(false);
        },
        onSyncServerProgress: (p) => print('[同步] $p%'),
      );
      HttpClient().init(baseUrl: _apiAddr);
      final login = await chatLogin(_phone1);
      print('[登录] userID=${login['userID']}');
      final userInfo = await OpenIM.iMManager.login(
        userID: login['userID']!,
        token: login['imToken']!,
      );
      expect(userInfo, isNotNull);
      await sync.future.timeout(const Duration(seconds: 30), onTimeout: () => false);
      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      print('[会话] 共 ${convs.length} 个');
      expect(convs, isNotEmpty);
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('用户1 发文本消息给用户2', () async {
      final sync = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (c, m) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync.isCompleted) sync.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync.isCompleted) sync.complete(false);
        },
      );
      HttpClient().init(baseUrl: _apiAddr);
      final login1 = await chatLogin(_phone1);
      await OpenIM.iMManager.login(userID: login1['userID']!, token: login1['imToken']!);
      await sync.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final login2 = await chatLogin(_phone2);
      final txt = OpenIM.iMManager.messageManager.createTextMessage(
        text: '互发测试: ${DateTime.now()}',
      );
      try {
        final sent = await OpenIM.iMManager.messageManager.sendMessage(
          message: txt,
          userID: login2['userID']!,
          offlinePushInfo: const OfflinePushInfo(title: '新消息', desc: '测试'),
        );
        print('[发送] 成功: ${sent.clientMsgID}');
        expect(sent.status, MessageStatus.succeeded);
      } catch (e) {
        print('[发送] 失败: $e');
      }
      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      expect(convs, isNotEmpty);
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('用户2 登录后能看到用户1发的消息', () async {
      final sync = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (c, m) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync.isCompleted) sync.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync.isCompleted) sync.complete(false);
        },
        onSyncServerProgress: (p) => print('[同步] $p%'),
      );
      HttpClient().init(baseUrl: _apiAddr);
      final login2 = await chatLogin(_phone2);
      print('[登录用户2] userID=${login2['userID']}');
      await OpenIM.iMManager.login(userID: login2['userID']!, token: login2['imToken']!);
      await sync.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      print('[用户2会话] 共 ${convs.length} 个');
      for (final c in convs) {
        print('  - ${c.conversationID}: showName=${c.showName}, unread=${c.unreadCount}');
      }
      expect(convs, isNotEmpty);

      final login1 = await chatLogin(_phone1);
      final convID = ConversationManager.genSingleConversationID(
        login2['userID']!,
        login1['userID']!,
      );
      final tc = convs.where((c) => c.conversationID == convID).toList();
      if (tc.isNotEmpty) {
        print(
          '[用户2] 与用户1会话: unread=${tc.first.unreadCount}, latest=${tc.first.latestMsg?.textElem?.content}',
        );
        expect(tc.first.latestMsg, isNotNull);
      }
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('两用户互发消息: 用户1发 → 用户2收 → 用户2回 → 用户1查看', () async {
      // ── 步骤1: 用户1登录并发送 ──
      final sync1 = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (c, m) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync1.isCompleted) sync1.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync1.isCompleted) sync1.complete(false);
        },
      );
      HttpClient().init(baseUrl: _apiAddr);
      final login1 = await chatLogin(_phone1);
      final login2Data = await chatLogin(_phone2);
      await OpenIM.iMManager.login(userID: login1['userID']!, token: login1['imToken']!);
      await sync1.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final ts = DateTime.now().millisecondsSinceEpoch;
      final msgText1 = '互发测试_from_user1_$ts';
      final txt1 = OpenIM.iMManager.messageManager.createTextMessage(text: msgText1);
      try {
        await OpenIM.iMManager.messageManager.sendMessage(
          message: txt1,
          userID: login2Data['userID']!,
          offlinePushInfo: OfflinePushInfo(title: '新消息', desc: msgText1),
        );
        print('[用户1] 发送成功: $msgText1');
      } catch (e) {
        print('[用户1] 发送: $e');
      }

      final convID = ConversationManager.genSingleConversationID(
        login1['userID']!,
        login2Data['userID']!,
      );
      final convs1 = await OpenIM.iMManager.conversationManager.getAllConversationList();
      final c1 = convs1.where((c) => c.conversationID == convID).toList();
      if (c1.isNotEmpty) {
        print('[用户1] 会话 latestMsg=${c1.first.latestMsg?.textElem?.content}');
        expect(c1.first.latestMsg, isNotNull);
      }

      await OpenIM.iMManager.logout();
      await GetIt.instance.reset();

      // ── 步骤2: 用户2登录、查看消息、回复 ──
      final sync2 = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (c, m) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync2.isCompleted) sync2.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync2.isCompleted) sync2.complete(false);
        },
      );
      HttpClient().init(baseUrl: _apiAddr);
      await OpenIM.iMManager.login(userID: login2Data['userID']!, token: login2Data['imToken']!);
      await sync2.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final convs2 = await OpenIM.iMManager.conversationManager.getAllConversationList();
      final c2 = convs2.where((c) => c.conversationID == convID).toList();
      print('[用户2] 会话数=${convs2.length}, 与用户1会话=${c2.length}');
      if (c2.isNotEmpty) {
        print(
          '[用户2] latestMsg=${c2.first.latestMsg?.textElem?.content}, unread=${c2.first.unreadCount}',
        );
      }

      final replyText = '互发测试_from_user2_$ts';
      final reply = OpenIM.iMManager.messageManager.createTextMessage(text: replyText);
      try {
        await OpenIM.iMManager.messageManager.sendMessage(
          message: reply,
          userID: login1['userID']!,
          offlinePushInfo: OfflinePushInfo(title: '新消息', desc: replyText),
        );
        print('[用户2] 回复成功: $replyText');
      } catch (e) {
        print('[用户2] 回复: $e');
      }

      final convs2After = await OpenIM.iMManager.conversationManager.getAllConversationList();
      final c2a = convs2After.where((c) => c.conversationID == convID).toList();
      if (c2a.isNotEmpty) {
        print('[用户2] 回复后 latestMsg=${c2a.first.latestMsg?.textElem?.content}');
        expect(c2a.first.latestMsg, isNotNull);
      }

      await OpenIM.iMManager.logout();
      await GetIt.instance.reset();

      // ── 步骤3: 用户1重新登录查看回复 ──
      final sync3 = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (c, m) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync3.isCompleted) sync3.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync3.isCompleted) sync3.complete(false);
        },
      );
      HttpClient().init(baseUrl: _apiAddr);
      await OpenIM.iMManager.login(userID: login1['userID']!, token: login1['imToken']!);
      await sync3.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final convs3 = await OpenIM.iMManager.conversationManager.getAllConversationList();
      final c3 = convs3.where((c) => c.conversationID == convID).toList();
      if (c3.isNotEmpty) {
        print(
          '[用户1重登] latestMsg=${c3.first.latestMsg?.textElem?.content}, unread=${c3.first.unreadCount}',
        );
        expect(c3.first.unreadCount, greaterThanOrEqualTo(0));
      }
    }, timeout: const Timeout(Duration(minutes: 5)));

    test('未读总数一致性', () async {
      final sync = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (c, m) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync.isCompleted) sync.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync.isCompleted) sync.complete(false);
        },
      );
      HttpClient().init(baseUrl: _apiAddr);
      final login = await chatLogin(_phone1);
      await OpenIM.iMManager.login(userID: login['userID']!, token: login['imToken']!);
      await sync.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final count = await OpenIM.iMManager.conversationManager.getTotalUnreadMsgCount();
      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      int sum = 0;
      for (final c in convs) {
        sum += c.unreadCount;
      }
      print('[验证] DB总未读=$count, 会话列表总未读=$sum');
      expect(count, sum);
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('标记已读后未读数归零', () async {
      final sync = Completer<bool>();
      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (c, m) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!sync.isCompleted) sync.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!sync.isCompleted) sync.complete(false);
        },
      );
      HttpClient().init(baseUrl: _apiAddr);
      final login = await chatLogin(_phone1);
      await OpenIM.iMManager.login(userID: login['userID']!, token: login['imToken']!);
      await sync.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      if (convs.isNotEmpty) {
        final target = convs.first;
        print('[已读前] ${target.conversationID}: unread=${target.unreadCount}');
        await OpenIM.iMManager.conversationManager.markConversationMessageAsRead(
          conversationID: target.conversationID,
        );
        final after = await OpenIM.iMManager.conversationManager.getMultipleConversation(
          conversationIDList: [target.conversationID],
        );
        print('[已读后] ${after.first.conversationID}: unread=${after.first.unreadCount}');
        expect(after.first.unreadCount, 0);
      }
    }, timeout: const Timeout(Duration(minutes: 2)));
  });
}
