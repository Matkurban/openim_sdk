  group('MsgSyncer-loadSeqs', () {
    test('空 DB → reinstalled=true', () async {
      final env = await createSyncerEnv();
      await env.syncer.loadSeqs();
      expect(env.syncer.reinstalled, isTrue);
      expect(env.syncer.syncedMaxSeqs, isEmpty);
      await destroyEnv(env.db, env.dir);
    });

    test('有会话 → reinstalled=false', () async {
      final env = await createSyncerEnv();
      await env.db.upsertConversation({'conversationID': 'a', 'conversationType': 1, 'maxSeq': 10});
      await env.db.upsertConversation({'conversationID': 'b', 'conversationType': 3, 'maxSeq': 25});
      await env.syncer.loadSeqs();
      expect(env.syncer.reinstalled, isFalse);
      expect(env.syncer.syncedMaxSeqs['a'], 10);
      expect(env.syncer.syncedMaxSeqs['b'], 25);
      await destroyEnv(env.db, env.dir);
    });
  });

