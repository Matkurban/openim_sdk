      await destroyEnv(env.db, env.dir);
    });

    test('更新已有用户', () async {
      final env = await createDbEnv();
      await env.db.insertOrUpdateUser({'userID': 'u1', 'nickname': '旧名称'});
      await env.db.insertOrUpdateUser({'userID': 'u1', 'nickname': '新名称'});
      final users = await env.db.getUsersByIDs(['u1']);
      expect(users.length, 1);
      expect(users.first['nickname'], '新名称');
      await destroyEnv(env.db, env.dir);
    });

    test('getUsersByIDs 批量查询', () async {
      final env = await createDbEnv();
