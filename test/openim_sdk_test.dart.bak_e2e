  group('MsgSyncer-collectMessageUpdate', () {
    test('普通消息聚合', () async {
      final env = await createSyncerEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      final updates = <String, ConvBatchUpdate>{};
      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'c1', sendID: 'u2', recvID: 'test_user_001', seq: 5, sendTime: t),
        'conv',
        updates,
      );
      expect(updates['conv']!.maxSeq, 5);
      expect(updates['conv']!.newUnreadCount, 1);
      await destroyEnv(env.db, env.dir);
    });

    test('自己消息不加 unread', () async {
      final env = await createSyncerEnv();
      final updates = <String, ConvBatchUpdate>{};
      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'c1', sendID: 'test_user_001', recvID: 'u2'),
        'conv',
        updates,
      );
      expect(updates['conv']!.newUnreadCount, 0);
      await destroyEnv(env.db, env.dir);
    });

    test('通知消息不聚合', () async {
      final env = await createSyncerEnv();
      final updates = <String, ConvBatchUpdate>{};
      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'n', sendID: 'sys', recvID: 'u1', contentType: 1201),
        'conv',
        updates,
      );
      expect(updates.containsKey('conv'), isFalse);
      await destroyEnv(env.db, env.dir);
    });

    test('多条累加', () async {
      final env = await createSyncerEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      final updates = <String, ConvBatchUpdate>{};
      for (var i = 1; i <= 3; i++) {
        env.syncer.collectMessageUpdate(
          makeMsg(
            clientMsgID: 'm$i',
            sendID: 'u2',
            recvID: 'test_user_001',
            seq: i,
            sendTime: t + i * 1000,
          ),
          'conv',
          updates,
        );
      }
      expect(updates['conv']!.maxSeq, 3);
      expect(updates['conv']!.newUnreadCount, 3);
      await destroyEnv(env.db, env.dir);
    });

    test('混合自己和他人消息', () async {
      final env = await createSyncerEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      final updates = <String, ConvBatchUpdate>{};
      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'm1', sendID: 'u2', recvID: 'test_user_001', seq: 1, sendTime: t),
        'conv',
        updates,
      );
      env.syncer.collectMessageUpdate(
        makeMsg(
          clientMsgID: 'm2',
          sendID: 'test_user_001',
          recvID: 'u2',
          seq: 2,
          sendTime: t + 1000,
        ),
        'conv',
        updates,
      );
      expect(updates['conv']!.maxSeq, 2);
      expect(updates['conv']!.newUnreadCount, 1); // 只有 m1 算未读
      await destroyEnv(env.db, env.dir);
    });
  });

  group('MsgSyncer-applyBatchUpdatesAndNotify', () {
    test('新会话创建', () async {
      final env = await createSyncerEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      final newIDs = <String>[];
      env.syncer.onNewConversation = (ids) => newIDs.addAll(ids);
      env.syncer.onTotalUnreadCountChanged = () {};
      final msg = makeMsg(
        clientMsgID: 'a1',
        sendID: 'u2',
        recvID: 'test_user_001',
        seq: 1,
        sendTime: t,
      );
      final update = ConvBatchUpdate(firstMsg: msg)
        ..latestMsg = msg
        ..latestMsgSendTime = t
        ..maxSeq = 1
        ..newUnreadCount = 1;
      await env.syncer.applyBatchUpdatesAndNotify({'conv1': update}, {});
      final conv = await env.db.getConversation('conv1');
      expect(conv!['unreadCount'], 1);
      expect(newIDs, contains('conv1'));
      await destroyEnv(env.db, env.dir);
    });

    test('已有会话更新', () async {
      final env = await createSyncerEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      await env.db.upsertConversation({
        'conversationID': 'conv1',
        'conversationType': 1,
        'maxSeq': 5,
        'unreadCount': 2,
      });
      final changedIDs = <String>[];
      env.syncer.onConversationChanged = (ids) => changedIDs.addAll(ids);
      env.syncer.onTotalUnreadCountChanged = () {};
      final msg = makeMsg(
        clientMsgID: 'a2',
        sendID: 'u2',
        recvID: 'test_user_001',
        seq: 6,
        sendTime: t,
      );
      final update = ConvBatchUpdate(firstMsg: msg)
        ..latestMsg = msg
        ..latestMsgSendTime = t
        ..maxSeq = 6
        ..newUnreadCount = 1;
      await env.syncer.applyBatchUpdatesAndNotify({'conv1': update}, {});
      final conv = await env.db.getConversation('conv1');
      expect(conv!['unreadCount'], 3);
      expect(conv['maxSeq'], 6);
      expect(changedIDs, contains('conv1'));
      await destroyEnv(env.db, env.dir);
    });

    test('空更新不崩溃', () async {
      final env = await createSyncerEnv();
      env.syncer.onNewConversation = (_) {};
      env.syncer.onTotalUnreadCountChanged = () {};
      await env.syncer.applyBatchUpdatesAndNotify({}, {});
      await destroyEnv(env.db, env.dir);
    });
  });

