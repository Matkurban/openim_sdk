// ===========================================================================
// 测试配置
// ===========================================================================
const _apiAddr = 'http://115.190.173.31:10002';
const _wsAddr = 'ws://115.190.173.31:10001';
const _chatAddr = 'http://115.190.173.31:10008';
const _phone1 = '13579885143';
const _phone2 = '13579885142';
const _password = '123456m';
const _areaCode = '+86';

// ===========================================================================
// 辅助函数
// ===========================================================================

/// 通过 Chat API 登录
Future<Map<String, String>> chatLogin(String phone) async {
  final dio = Dio(
    BaseOptions(
      baseUrl: _chatAddr,
      headers: {'operationID': 'test_${DateTime.now().millisecondsSinceEpoch}'},
    ),
  );
  final resp = await dio.post(
    '/account/login',
    data: {
      'phoneNumber': phone,
      'password': ImUtils.generateMD5(_password),
      'areaCode': _areaCode,
      'platform': 5,
    },
  );
  final body = resp.data as Map<String, dynamic>;
  expect(body['errCode'], 0, reason: '登录失败: ${body['errMsg']}');
  final data = body['data'] as Map<String, dynamic>;
  return {
    'chatToken': data['chatToken'] as String? ?? '',
    'userID': data['userID'] as String? ?? '',
    'imToken': data['imToken'] as String? ?? '',
  };
}

/// 创建独立 DB 环境
Future<({DatabaseService db, Directory dir})> createDbEnv({String userID = 'test_user_001'}) async {
  final dir = Directory.systemTemp.createTempSync('openim_test_');
  final db = DatabaseService();
  await db.init(userID: userID, dataDir: dir.path);
  return (db: db, dir: dir);
}

/// 创建 MsgSyncer 测试环境
Future<({MsgSyncer syncer, DatabaseService db, Directory dir})> createSyncerEnv({
  String userID = 'test_user_001',
}) async {
  final dir = Directory.systemTemp.createTempSync('openim_test_');
  final db = DatabaseService();
  await db.init(userID: userID, dataDir: dir.path);
  final ws = WsConnectionManager();
  final api = ImApiService();
  final syncer = MsgSyncer(ws: ws, db: db, api: api);
  syncer.setLoginUserID(userID);
  return (syncer: syncer, db: db, dir: dir);
}

/// 创建 Manager 层测试环境（注册 GetIt）
Future<
  ({
    DatabaseService db,
    Directory dir,
    ConversationManager convMgr,
    MessageManager msgMgr,
    FriendshipManager friendMgr,
    GroupManager groupMgr,
    UserManager userMgr,
  })
>
createManagerEnv({String userID = 'test_user_001'}) async {
  final dir = Directory.systemTemp.createTempSync('openim_test_');
  final db = DatabaseService();
  await db.init(userID: userID, dataDir: dir.path);
  final getIt = GetIt.instance;
  if (getIt.isRegistered<DatabaseService>()) getIt.unregister<DatabaseService>();
  getIt.registerSingleton<DatabaseService>(db);
  if (!getIt.isRegistered<ImApiService>()) {
    getIt.registerSingleton<ImApiService>(ImApiService());
  }
  return (
    db: db,
    dir: dir,
    convMgr: ConversationManager(),
    msgMgr: MessageManager(),
    friendMgr: FriendshipManager(),
    groupMgr: GroupManager(),
    userMgr: UserManager(),
  );
}

/// 销毁 DB 环境
Future<void> destroyEnv(DatabaseService db, Directory dir) async {
  await db.close();
  try {
    dir.deleteSync(recursive: true);
  } catch (_) {}
}

/// 销毁 Manager 环境
Future<void> destroyManagerEnv(DatabaseService db, Directory dir) async {
  await db.close();
  final getIt = GetIt.instance;
  if (getIt.isRegistered<DatabaseService>()) getIt.unregister<DatabaseService>();
  if (getIt.isRegistered<ImApiService>()) getIt.unregister<ImApiService>();
  try {
    dir.deleteSync(recursive: true);
  } catch (_) {}
}

/// 构造推送 WS 消息
GeneralWsResp makePushResp(Map<String, dynamic> payload) {
  return GeneralWsResp(
    reqIdentifier: 2001,
    errCode: 0,
    errMsg: '',
    msgIncr: '',
    operationID: '',
    data: utf8.encode(jsonEncode(payload)),
  );
}

/// 构造消息 Map
Map<String, dynamic> makeMsg({
  required String clientMsgID,
  required String sendID,
  required String recvID,
  int seq = 1,
  int contentType = 101,
  int sessionType = 1,
  String? content,
  int? sendTime,
  String groupID = '',
  String senderNickname = '',
  String senderFaceUrl = '',
}) {
  final t = sendTime ?? DateTime.now().millisecondsSinceEpoch;
  return {
    'clientMsgID': clientMsgID,
    'serverMsgID': 'srv_$clientMsgID',
    'sendID': sendID,
    'recvID': recvID,
    'senderNickname': senderNickname,
    'senderFaceUrl': senderFaceUrl,
    'sessionType': sessionType,
    'contentType': contentType,
    'content': content ?? jsonEncode({'content': 'test'}),
    'seq': seq,
    'sendTime': t,
    'createTime': t,
    'status': 2,
    'groupID': groupID,
  };
}

