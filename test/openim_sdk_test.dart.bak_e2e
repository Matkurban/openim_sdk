    test('createQuoteMessage', () async {
      final env = await createManagerEnv();
      final original = env.msgMgr.createTextMessage(text: '原始消息');
      final quote = env.msgMgr.createQuoteMessage(text: '引用回复', quoteMsg: original);
      expect(quote.contentType, MessageType.quote);
      expect(quote.quoteElem?.text, '引用回复');
      expect(quote.quoteElem?.quoteMessage?.textElem?.content, '原始消息');
      await destroyManagerEnv(env.db, env.dir);
    });

    test('createAdvancedTextMessage', () async {
      final env = await createManagerEnv();
      final msg = env.msgMgr.createAdvancedTextMessage(text: '富文本');
      expect(msg.contentType, MessageType.advancedText);
      expect(msg.advancedTextElem?.text, '富文本');
      await destroyManagerEnv(env.db, env.dir);
    });

    test('createForwardMessage', () async {
      final env = await createManagerEnv();
      final original = env.msgMgr.createTextMessage(text: '被转发');
      final forwarded = env.msgMgr.createForwardMessage(message: original);
      expect(forwarded.clientMsgID, isNot(original.clientMsgID));
      expect(forwarded.textElem?.content, '被转发');
      await destroyManagerEnv(env.db, env.dir);
    });

    test('createMergerMessage', () async {
      final env = await createManagerEnv();
      final msg1 = env.msgMgr.createTextMessage(text: '消息1');
      final msg2 = env.msgMgr.createTextMessage(text: '消息2');
      final merged = env.msgMgr.createMergerMessage(
        messageList: [msg1, msg2],
        title: '合并记录',
        summaryList: ['张三: 消息1', '李四: 消息2'],
      );
      expect(merged.contentType, MessageType.merger);
      expect(merged.mergeElem?.title, '合并记录');
      expect(merged.mergeElem?.abstractList?.length, 2);
      await destroyManagerEnv(env.db, env.dir);
    });

    test('clientMsgID 100次唯一', () async {
      final env = await createManagerEnv();
      final ids = <String>{};
      for (var i = 0; i < 100; i++) {
        ids.add(env.msgMgr.createTextMessage(text: 'msg_$i').clientMsgID!);
      }
      expect(ids.length, 100);
      await destroyManagerEnv(env.db, env.dir);
    });
  });

  // ── 3.2 MessageManager - 本地消息操作 ──
  group('MessageManager-本地操作', () {
    test('sendMessage 写入 DB 并更新会话', () async {
      final env = await createManagerEnv();
      final msg = env.msgMgr.createTextMessage(text: '发送测试');
      final sent = await env.msgMgr.sendMessage(
        message: msg,
        userID: 'target_user',
        offlinePushInfo: const OfflinePushInfo(title: '新消息'),
      );
      expect(sent.status, MessageStatus.succeeded);

      // 验证 DB 存在该消息
      final dbMsg = await env.db.getMessage(msg.clientMsgID!);
      expect(dbMsg, isNotNull);
      expect(dbMsg!['status'], MessageStatus.succeeded.value);

      // 验证会话创建
      final convID = ConversationManager.genSingleConversationID('test_user_001', 'target_user');
      final conv = await env.db.getConversation(convID);
      expect(conv, isNotNull);
      await destroyManagerEnv(env.db, env.dir);
    });

    test('insertSingleMessageToLocalStorage', () async {
      final env = await createManagerEnv();
      final msg = env.msgMgr.createTextMessage(text: '插入本地');
      final inserted = await env.msgMgr.insertSingleMessageToLocalStorage(
        receiverID: 'u2',
        senderID: 'u1',
        message: msg,
      );
      expect(inserted.sendID, 'u1');
      expect(inserted.recvID, 'u2');
      expect(await env.db.getMessage(msg.clientMsgID!), isNotNull);
      await destroyManagerEnv(env.db, env.dir);
    });

    test('insertGroupMessageToLocalStorage', () async {
      final env = await createManagerEnv();
      final msg = env.msgMgr.createTextMessage(text: '群消息');
      final inserted = await env.msgMgr.insertGroupMessageToLocalStorage(
        groupID: 'g1',
        senderID: 'u1',
        message: msg,
      );
      expect(inserted.groupID, 'g1');
      expect(inserted.sessionType, ConversationType.superGroup);
      await destroyManagerEnv(env.db, env.dir);
    });
  });

