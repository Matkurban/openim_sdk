    test('markMessageAsRead + markMessagesAsRead', () async {
      final env = await createDbEnv();
      await env.db.insertMessage({
        'clientMsgID': 'mr1',
        'sendID': 'u1',
        'recvID': 'u2',
        'contentType': 101,
        'sessionType': 1,
        'seq': 1,
        'sendTime': 1,
        'status': 2,
        'isRead': false,
      });
      await env.db.insertMessage({
        'clientMsgID': 'mr2',
        'sendID': 'u1',
        'recvID': 'u2',
        'contentType': 101,
        'sessionType': 1,
        'seq': 2,
        'sendTime': 2,
        'status': 2,
        'isRead': false,
      });
      await env.db.markMessageAsRead('mr1');
      expect((await env.db.getMessage('mr1'))!['isRead'], true);
      await env.db.markMessagesAsRead(['mr2']);
      expect((await env.db.getMessage('mr2'))!['isRead'], true);
      await destroyEnv(env.db, env.dir);
    });

