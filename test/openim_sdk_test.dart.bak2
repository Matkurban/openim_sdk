  // =========================================================================
  // 十、WS 消息格式验证
  // =========================================================================
  group('WS 消息格式验证', () {
    test('GeneralWsResp 解析', () {
      final testData = utf8.encode(jsonEncode({'key': 'value'}));
      final resp = GeneralWsResp(
        reqIdentifier: 2001,
        errCode: 0,
        errMsg: '',
        msgIncr: 'test_incr',
        operationID: 'op_test',
        data: testData,
      );
      expect(resp.reqIdentifier, 2001);
      expect(resp.msgIncr, 'test_incr');
      final decoded = jsonDecode(utf8.decode(resp.data)) as Map<String, dynamic>;
      expect(decoded['key'], 'value');
    });

    test('推送消息结构: msgs 按 conversationID 分组', () {
      final pushPayload = {
        'msgs': {
          'si_user1_user2': {
            'msgs': [
              {'clientMsgID': 'msg1', 'seq': 1, 'contentType': 101},
              {'clientMsgID': 'msg2', 'seq': 2, 'contentType': 101},
            ],
          },
          'sg_group1': {
            'msgs': [
              {'clientMsgID': 'msg3', 'seq': 5, 'contentType': 101},
            ],
          },
        },
        'notificationMsgs': {
          'si_user1_user2': {
            'msgs': [
              {'clientMsgID': 'notif1', 'seq': 3, 'contentType': 1300},
            ],
          },
        },
      };

      final decoded = jsonDecode(jsonEncode(pushPayload)) as Map<String, dynamic>;
      final msgs = decoded['msgs'] as Map<String, dynamic>;
      expect(msgs.keys, containsAll(['si_user1_user2', 'sg_group1']));
      expect((msgs['si_user1_user2'] as Map)['msgs'], hasLength(2));
    });
  });

  // =========================================================================
  // 十一、集成测试 - 真实服务器
  // =========================================================================
  group('集成测试 - 真实服务器', () {
    setUp(() async {
      if (GetIt.instance.isRegistered<InitConfig>()) {
        await GetIt.instance.reset();
      }
    });

    tearDown(() async {
      try {
        await OpenIM.iMManager.logout();
      } catch (_) {}
      try {
        await GetIt.instance.reset();
      } catch (_) {}
    });

    test('登录并完成初始会话同步', () async {
      final syncFinished = Completer<bool>();

      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () => print('[连接] 成功'),
          onConnectFailed: (code, msg) => print('[连接] 失败: $code $msg'),
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );

      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(false);
        },
        onSyncServerProgress: (p) => print('[同步] $p%'),
      );

      HttpClient().init(baseUrl: _apiAddr);
      final login = await chatLogin(_phone1);
      print('[登录] userID=${login['userID']}');

      final userInfo = await OpenIM.iMManager.login(
        userID: login['userID']!,
        token: login['imToken']!,
      );
      expect(userInfo, isNotNull);
      print('[登录] nickname=${userInfo?.nickname}');

      await syncFinished.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final conversations = await OpenIM.iMManager.conversationManager.getAllConversationList();
      print('[会话] 共 ${conversations.length} 个');
      for (final c in conversations) {
        print(
          '  - ${c.conversationID}: showName=${c.showName}, '
          'type=${c.conversationType}, unread=${c.unreadCount}, '
          'hasLatest=${c.latestMsg != null}',
        );
      }
      expect(conversations, isNotEmpty);
      for (final c in conversations) {
        expect(c.conversationID, isNotEmpty);
      }
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('发送消息后会话列表应更新', () async {
      final syncFinished = Completer<bool>();

      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (code, msg) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );

      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(false);
        },
      );

      HttpClient().init(baseUrl: _apiAddr);
      final login1 = await chatLogin(_phone1);
      await OpenIM.iMManager.login(userID: login1['userID']!, token: login1['imToken']!);
      await syncFinished.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final login2 = await chatLogin(_phone2);
      try {
        final textMsg = OpenIM.iMManager.messageManager.createTextMessage(
          text: '集成测试 ${DateTime.now()}',
        );
        await OpenIM.iMManager.messageManager.sendMessage(
          message: textMsg,
          userID: login2['userID']!,
          offlinePushInfo: OfflinePushInfo(title: '新消息', desc: '测试'),
        );
        print('[发送] 成功');
      } catch (e) {
        print('[发送] 失败: $e');
      }

      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      expect(convs, isNotEmpty);
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('未读总数应与会话列表一致', () async {
      final syncFinished = Completer<bool>();

      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (code, msg) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(false);
        },
      );

      HttpClient().init(baseUrl: _apiAddr);
      final login = await chatLogin(_phone1);
      await OpenIM.iMManager.login(userID: login['userID']!, token: login['imToken']!);
      await syncFinished.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      final count = await OpenIM.iMManager.conversationManager.getTotalUnreadMsgCount();
      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      int sum = 0;
      for (final c in convs) {
        sum += c.unreadCount;
      }
      print('[验证] DB总未读=$count, 会话列表总未读=$sum');
      expect(count, sum);
    }, timeout: const Timeout(Duration(minutes: 2)));
  });
}
