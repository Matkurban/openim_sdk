  // =========================================================================
  // 八、processNotificationMessage — 通知消息处理
  // =========================================================================
  group('processNotificationMessage', () {
    test('更新会话 maxSeq', () async {
      final env = await createTestEnv();
      final convID = 'si_notif_001';

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 5,
      });

      env.syncer.processNotificationMessage(
        makeMsg(clientMsgID: 'n1', sendID: 'sys', recvID: 'u1', seq: 10, contentType: 1300),
        convID,
      );
      await Future.delayed(const Duration(milliseconds: 500));

      final conv = await env.db.getConversation(convID);
      expect(conv!['maxSeq'], 10);
      expect(env.syncer.syncedMaxSeqs[convID], 10);

      await destroyTestEnv(env.db, env.dir);
    });

    test('通过 onNewMsg 回调分发', () async {
      final env = await createTestEnv();
      final received = <String>[];
      env.syncer.onNewMsg = (msg) => received.add(msg['clientMsgID'] as String);

      env.syncer.processNotificationMessage(
        makeMsg(clientMsgID: 'n2', sendID: 'sys', recvID: 'u1', seq: 3, contentType: 1201),
        'si_notif_002',
      );

      expect(received, contains('n2'));

      await destroyTestEnv(env.db, env.dir);
    });

    test('seq=0 不更新 maxSeq', () async {
      final env = await createTestEnv();
      final convID = 'si_notif_003';

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 5,
      });

      env.syncer.processNotificationMessage(
        makeMsg(clientMsgID: 'n3', sendID: 'sys', recvID: 'u1', seq: 0, contentType: 1300),
        convID,
      );
      await Future.delayed(const Duration(milliseconds: 500));

      final conv = await env.db.getConversation(convID);
      expect(conv!['maxSeq'], 5);

      await destroyTestEnv(env.db, env.dir);
    });

    test('小于现有 maxSeq 的 seq 不更新', () async {
      final env = await createTestEnv();
      final convID = 'si_notif_004';

      env.syncer.syncedMaxSeqs[convID] = 20;

      env.syncer.processNotificationMessage(
        makeMsg(clientMsgID: 'n4', sendID: 'sys', recvID: 'u1', seq: 15, contentType: 1300),
        convID,
      );

      expect(env.syncer.syncedMaxSeqs[convID], 20);

      await destroyTestEnv(env.db, env.dir);
    });
  });

