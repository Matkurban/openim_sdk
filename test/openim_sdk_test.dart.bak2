import 'dart:async';
import 'dart:convert';
import 'dart:io';
import 'dart:typed_data';

import 'package:dio/dio.dart';
import 'package:get_it/get_it.dart';
import 'package:logging/logging.dart';
import 'package:openim_sdk/openim_sdk.dart';
import 'package:openim_sdk/src/db/database_service.dart';
import 'package:openim_sdk/src/network/http_client.dart';
import 'package:openim_sdk/src/network/msg_syncer.dart';
import 'package:openim_sdk/src/network/ws_codec.dart';
import 'package:openim_sdk/src/network/ws_connection_manager.dart';
import 'package:openim_sdk/src/services/im_api_service.dart';
import 'package:openim_sdk/src/utils/im_utils.dart';
import 'package:test/test.dart';

// ---------------------------------------------------------------------------
// 测试配置
// ---------------------------------------------------------------------------
const _apiAddr = 'http://115.190.173.31:10002';
const _wsAddr = 'ws://115.190.173.31:10001';
const _chatAddr = 'http://115.190.173.31:10008';
const _phone1 = '13579885143';
const _phone2 = '13579885142';
const _password = '123456m';
const _areaCode = '+86';

// ---------------------------------------------------------------------------
// 辅助函数
// ---------------------------------------------------------------------------

/// 通过 Chat API 登录并返回 {chatToken, userID, imToken}
Future<Map<String, String>> chatLogin(String phone) async {
  final dio = Dio(
    BaseOptions(
      baseUrl: _chatAddr,
      headers: {'operationID': 'test_${DateTime.now().millisecondsSinceEpoch}'},
    ),
  );
  final response = await dio.post(
    '/account/login',
    data: {
      'phoneNumber': phone,
      'password': ImUtils.generateMD5(_password),
      'areaCode': _areaCode,
      'platform': 5,
    },
  );
  final body = response.data as Map<String, dynamic>;
  expect(body['errCode'], 0, reason: '登录失败: ${body['errMsg']}');
  final data = body['data'] as Map<String, dynamic>;
  return {
    'chatToken': data['chatToken'] as String? ?? '',
    'userID': data['userID'] as String? ?? '',
    'imToken': data['imToken'] as String? ?? '',
  };
}

/// 创建隔离的 MsgSyncer + DatabaseService 测试环境
Future<({MsgSyncer syncer, DatabaseService db, Directory dir})> createTestEnv({
  String userID = 'test_user_001',
}) async {
  final dir = Directory.systemTemp.createTempSync('openim_test_');
  final db = DatabaseService();
  await db.init(userID: userID, dataDir: dir.path);
  final ws = WsConnectionManager();
  final api = ImApiService();
  final syncer = MsgSyncer(ws: ws, db: db, api: api);
  syncer.setLoginUserID(userID);
  return (syncer: syncer, db: db, dir: dir);
}

/// 销毁测试环境
Future<void> destroyTestEnv(DatabaseService db, Directory dir) async {
  await db.close();
  try {
    dir.deleteSync(recursive: true);
  } catch (_) {}
}

/// 构造推送消息的 GeneralWsResp
GeneralWsResp makePushResp(Map<String, dynamic> pushPayload) {
  return GeneralWsResp(
    reqIdentifier: 2001,
    errCode: 0,
    errMsg: '',
    msgIncr: '',
    operationID: '',
    data: utf8.encode(jsonEncode(pushPayload)),
  );
}

/// 构造一条消息 Map
Map<String, dynamic> makeMsg({
  required String clientMsgID,
  required String sendID,
  required String recvID,
  int seq = 1,
  int contentType = 101,
  int sessionType = 1,
  String? content,
  int? sendTime,
  String groupID = '',
  String senderNickname = '',
  String senderFaceUrl = '',
}) {
  final t = sendTime ?? DateTime.now().millisecondsSinceEpoch;
  return {
    'clientMsgID': clientMsgID,
    'serverMsgID': 'srv_$clientMsgID',
    'sendID': sendID,
    'recvID': recvID,
    'senderNickname': senderNickname,
    'senderFaceUrl': senderFaceUrl,
    'sessionType': sessionType,
    'contentType': contentType,
    'content': content ?? jsonEncode({'content': 'test'}),
    'seq': seq,
    'sendTime': t,
    'createTime': t,
    'status': 2,
    'groupID': groupID,
  };
}

// ---------------------------------------------------------------------------
// 测试主体
// ---------------------------------------------------------------------------
void main() {
  Logger.root.level = Level.INFO;
  Logger.root.onRecord.listen((rec) {
    // ignore: avoid_print
    print('${rec.level.name}: ${rec.loggerName}: ${rec.message}');
  });

  // =========================================================================
  // 一、setLoginUserID
  // =========================================================================
  group('setLoginUserID', () {
    test('设置用户 ID 后推送消息能正确识别自己', () async {
      final env = await createTestEnv();
      final convID = 'si_test_user_001_test_user_002';
      final t = DateTime.now().millisecondsSinceEpoch;

      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'self_msg',
                  sendID: 'test_user_001',
                  recvID: 'test_user_002',
                  sendTime: t,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 1));
      final conv = await env.db.getConversation(convID);
      expect(conv, isNotNull);
      expect(conv!['unreadCount'], 0);

      await destroyTestEnv(env.db, env.dir);
    });
  });

  // =========================================================================
  // 二、loadSeqs — 从本地数据库加载已同步的 seq
  // =========================================================================
  group('loadSeqs', () {
    test('空数据库 → reinstalled=true, syncedMaxSeqs 为空', () async {
      final env = await createTestEnv();

      await env.syncer.loadSeqs();
      expect(env.syncer.reinstalled, isTrue);
      expect(env.syncer.syncedMaxSeqs, isEmpty);

      await destroyTestEnv(env.db, env.dir);
    });

    test('有会话数据 → reinstalled=false, 正确加载各会话 maxSeq', () async {
      final env = await createTestEnv();

      await env.db.upsertConversation({
        'conversationID': 'conv_a',
        'conversationType': 1,
        'maxSeq': 10,
      });
      await env.db.upsertConversation({
        'conversationID': 'conv_b',
        'conversationType': 3,
        'maxSeq': 25,
      });

      await env.syncer.loadSeqs();
      expect(env.syncer.reinstalled, isFalse);
      expect(env.syncer.syncedMaxSeqs['conv_a'], 10);
      expect(env.syncer.syncedMaxSeqs['conv_b'], 25);

      await destroyTestEnv(env.db, env.dir);
    });

    test('maxSeq=0 的会话也应被加载', () async {
      final env = await createTestEnv();

      await env.db.upsertConversation({
        'conversationID': 'conv_zero',
        'conversationType': 1,
        'maxSeq': 0,
      });

      await env.syncer.loadSeqs();
      expect(env.syncer.reinstalled, isFalse);
      expect(env.syncer.syncedMaxSeqs['conv_zero'], 0);

      await destroyTestEnv(env.db, env.dir);
    });
  });

  // =========================================================================
  // 三、batchAddFaceURLAndName — 批量补充会话名称/头像
  // =========================================================================
  group('batchAddFaceURLAndName', () {
    test('单聊会话 - 优先使用好友备注作为 showName', () async {
      final env = await createTestEnv();

      await env.db.upsertFriend({
        'ownerUserID': 'test_user_001',
        'friendUserID': 'friend_001',
        'remark': '好友备注名',
        'nickname': '好友昵称',
        'faceURL': 'https://friend.face/1.png',
      });

      final convs = [
        {'conversationID': 'si_001_friend', 'conversationType': 1, 'userID': 'friend_001'},
      ];

      await env.syncer.batchAddFaceURLAndName(convs);

      expect(convs[0]['showName'], '好友备注名');
      expect(convs[0]['faceURL'], 'https://friend.face/1.png');

      await destroyTestEnv(env.db, env.dir);
    });

    test('单聊会话 - 无备注时使用好友昵称', () async {
      final env = await createTestEnv();

      await env.db.upsertFriend({
        'ownerUserID': 'test_user_001',
        'friendUserID': 'friend_002',
        'remark': '',
        'nickname': '好友昵称B',
        'faceURL': 'https://friend.face/2.png',
      });

      final convs = [
        {'conversationID': 'si_001_002', 'conversationType': 1, 'userID': 'friend_002'},
      ];
      await env.syncer.batchAddFaceURLAndName(convs);
      expect(convs[0]['showName'], '好友昵称B');

      await destroyTestEnv(env.db, env.dir);
    });

    test('单聊会话 - 非好友则从用户表查', () async {
      final env = await createTestEnv();

      await env.db.insertOrUpdateUser({
        'userID': 'stranger_001',
        'nickname': '陌生人昵称',
        'faceURL': 'https://stranger/1.png',
      });

      final convs = [
        {'conversationID': 'si_001_stranger', 'conversationType': 1, 'userID': 'stranger_001'},
      ];
      await env.syncer.batchAddFaceURLAndName(convs);
      expect(convs[0]['showName'], '陌生人昵称');
      expect(convs[0]['faceURL'], 'https://stranger/1.png');

      await destroyTestEnv(env.db, env.dir);
    });

    test('群聊会话 - 使用群名和群头像', () async {
      final env = await createTestEnv();

      await env.db.upsertGroup({
        'groupID': 'group_001',
        'groupName': '测试群聊',
        'faceURL': 'https://group.face/1.png',
      });

      final convs = [
        {'conversationID': 'sg_group_001', 'conversationType': 3, 'groupID': 'group_001'},
      ];
      await env.syncer.batchAddFaceURLAndName(convs);
      expect(convs[0]['showName'], '测试群聊');
      expect(convs[0]['faceURL'], 'https://group.face/1.png');

      await destroyTestEnv(env.db, env.dir);
    });

    test('本地无匹配数据时不崩溃', () async {
      final env = await createTestEnv();

      final convs = [
        {'conversationID': 'si_unknown', 'conversationType': 1, 'userID': 'no_such_user'},
        {'conversationID': 'sg_unknown', 'conversationType': 3, 'groupID': 'no_such_group'},
      ];
      await env.syncer.batchAddFaceURLAndName(convs);
      expect(convs[0].containsKey('showName'), isFalse);

      await destroyTestEnv(env.db, env.dir);
    });

    test('批量混合会话 - 单聊+群聊同时处理', () async {
      final env = await createTestEnv();

      await env.db.upsertFriend({
        'ownerUserID': 'test_user_001',
        'friendUserID': 'f1',
        'remark': '朋友1',
        'nickname': 'nick1',
        'faceURL': 'https://f1.png',
      });
      await env.db.upsertGroup({'groupID': 'g1', 'groupName': '群1', 'faceURL': 'https://g1.png'});

      final convs = [
        {'conversationID': 'si_f1', 'conversationType': 1, 'userID': 'f1'},
        {'conversationID': 'sg_g1', 'conversationType': 3, 'groupID': 'g1'},
      ];
      await env.syncer.batchAddFaceURLAndName(convs);
      expect(convs[0]['showName'], '朋友1');
      expect(convs[1]['showName'], '群1');

      await destroyTestEnv(env.db, env.dir);
    });
  });

  // =========================================================================
  // 四、processPulledMsgs — 拉取消息处理
  // =========================================================================
  group('processPulledMsgs', () {
    test('普通消息写入 chatLog 并更新会话 latestMsg', () async {
      final env = await createTestEnv();
      final convID = 'si_conv_pull_001';
      final t = DateTime.now().millisecondsSinceEpoch;

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 0,
      });

      await env.syncer.processPulledMsgs({
        convID: {
          'msgs': [
            makeMsg(
              clientMsgID: 'pull_001',
              sendID: 'u2',
              recvID: 'test_user_001',
              seq: 5,
              sendTime: t,
            ),
          ],
        },
      });

      final msg = await env.db.getMessage('pull_001');
      expect(msg, isNotNull);
      expect(msg!['seq'], 5);

      final conv = await env.db.getConversation(convID);
      expect(conv!['maxSeq'], 5);
      final latestMsg = jsonDecode(conv['latestMsg'] as String);
      expect(latestMsg['clientMsgID'], 'pull_001');

      await destroyTestEnv(env.db, env.dir);
    });

    test('通知消息不写入 chatLog 但更新 maxSeq', () async {
      final env = await createTestEnv();
      final convID = 'si_conv_pull_002';

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 0,
      });

      await env.syncer.processPulledMsgs({
        convID: {
          'msgs': [
            makeMsg(
              clientMsgID: 'notif_pull_001',
              sendID: 'system',
              recvID: 'test_user_001',
              seq: 10,
              contentType: 1201,
            ),
          ],
        },
      });

      final msg = await env.db.getMessage('notif_pull_001');
      expect(msg, isNull);

      final conv = await env.db.getConversation(convID);
      expect(conv!['maxSeq'], 10);
      expect(conv['latestMsg'], isNull);

      await destroyTestEnv(env.db, env.dir);
    });

    test('混合消息 - latestMsg 选 sendTime 最新的普通消息', () async {
      final env = await createTestEnv();
      final convID = 'si_conv_pull_003';
      final t = DateTime.now().millisecondsSinceEpoch;

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 0,
      });

      await env.syncer.processPulledMsgs({
        convID: {
          'msgs': [
            makeMsg(clientMsgID: 'old_msg', sendID: 'u2', recvID: 'u1', seq: 1, sendTime: t),
            makeMsg(
              clientMsgID: 'notif_msg',
              sendID: 'sys',
              recvID: 'u1',
              seq: 2,
              sendTime: t + 5000,
              contentType: 1300,
            ),
            makeMsg(clientMsgID: 'new_msg', sendID: 'u2', recvID: 'u1', seq: 3, sendTime: t + 2000),
          ],
        },
      });

      final conv = await env.db.getConversation(convID);
      expect(conv!['maxSeq'], 3);
      final latestMsg = jsonDecode(conv['latestMsg'] as String);
      expect(latestMsg['clientMsgID'], 'new_msg');

      await destroyTestEnv(env.db, env.dir);
    });

    test('空消息列表不崩溃', () async {
      final env = await createTestEnv();
      await env.syncer.processPulledMsgs({});
      await env.syncer.processPulledMsgs({
        'conv_empty': {'msgs': []},
      });
      await destroyTestEnv(env.db, env.dir);
    });

    test('多个会话在同一批次中处理', () async {
      final env = await createTestEnv();
      final t = DateTime.now().millisecondsSinceEpoch;

      await env.db.upsertConversation({'conversationID': 'c1', 'conversationType': 1, 'maxSeq': 0});
      await env.db.upsertConversation({'conversationID': 'c2', 'conversationType': 1, 'maxSeq': 0});

      await env.syncer.processPulledMsgs({
        'c1': {
          'msgs': [makeMsg(clientMsgID: 'c1m1', sendID: 'u2', recvID: 'u1', seq: 5, sendTime: t)],
        },
        'c2': {
          'msgs': [makeMsg(clientMsgID: 'c2m1', sendID: 'u3', recvID: 'u1', seq: 8, sendTime: t)],
        },
      });

      final conv1 = await env.db.getConversation('c1');
      final conv2 = await env.db.getConversation('c2');
      expect(conv1!['maxSeq'], 5);
      expect(conv2!['maxSeq'], 8);

      await destroyTestEnv(env.db, env.dir);
    });
  });

  // =========================================================================
  // 五、collectMessageUpdate — 单条消息聚合
  // =========================================================================
  group('collectMessageUpdate', () {
    test('普通消息正确聚合到 ConvBatchUpdate', () async {
      final env = await createTestEnv();
      final t = DateTime.now().millisecondsSinceEpoch;
      final convUpdates = <String, ConvBatchUpdate>{};
      final convID = 'si_collect_001';

      final msg = makeMsg(
        clientMsgID: 'c1',
        sendID: 'other_user',
        recvID: 'test_user_001',
        seq: 5,
        sendTime: t,
      );

      env.syncer.collectMessageUpdate(msg, convID, convUpdates);

      expect(convUpdates.containsKey(convID), isTrue);
      final update = convUpdates[convID]!;
      expect(update.maxSeq, 5);
      expect(update.newUnreadCount, 1);
      expect(update.latestMsg!['clientMsgID'], 'c1');
      expect(update.latestMsgSendTime, t);

      await destroyTestEnv(env.db, env.dir);
    });

    test('自己的消息不增加 newUnreadCount', () async {
      final env = await createTestEnv();
      final convUpdates = <String, ConvBatchUpdate>{};
      final convID = 'si_collect_002';
      final t = DateTime.now().millisecondsSinceEpoch;

      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'self1', sendID: 'test_user_001', recvID: 'u2', sendTime: t),
        convID,
        convUpdates,
      );

      expect(convUpdates[convID]!.newUnreadCount, 0);
      expect(convUpdates[convID]!.maxSeq, 1);

      await destroyTestEnv(env.db, env.dir);
    });

    test('多条消息聚合 - latestMsg 选最新, unread 累加', () async {
      final env = await createTestEnv();
      final convUpdates = <String, ConvBatchUpdate>{};
      final convID = 'si_collect_003';
      final t = DateTime.now().millisecondsSinceEpoch;

      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'm1', sendID: 'u2', recvID: 'test_user_001', seq: 1, sendTime: t),
        convID,
        convUpdates,
      );
      env.syncer.collectMessageUpdate(
        makeMsg(
          clientMsgID: 'm2',
          sendID: 'u2',
          recvID: 'test_user_001',
          seq: 2,
          sendTime: t + 1000,
        ),
        convID,
        convUpdates,
      );
      env.syncer.collectMessageUpdate(
        makeMsg(
          clientMsgID: 'm3',
          sendID: 'u2',
          recvID: 'test_user_001',
          seq: 3,
          sendTime: t + 2000,
        ),
        convID,
        convUpdates,
      );

      final update = convUpdates[convID]!;
      expect(update.newUnreadCount, 3);
      expect(update.maxSeq, 3);
      expect(update.latestMsg!['clientMsgID'], 'm3');

      await destroyTestEnv(env.db, env.dir);
    });

    test('通知消息 (contentType>=1000) 不聚合到 ConvBatchUpdate', () async {
      final env = await createTestEnv();
      final convUpdates = <String, ConvBatchUpdate>{};
      final convID = 'si_collect_004';
      final t = DateTime.now().millisecondsSinceEpoch;

      env.syncer.collectMessageUpdate(
        makeMsg(
          clientMsgID: 'notif1',
          sendID: 'system',
          recvID: 'test_user_001',
          seq: 5,
          contentType: 1201,
          sendTime: t,
        ),
        convID,
        convUpdates,
      );

      expect(convUpdates.containsKey(convID), isFalse);

      await destroyTestEnv(env.db, env.dir);
    });

    test('seq=0 临时消息 (typing) 触发 onNewMsg 但不聚合', () async {
      final env = await createTestEnv();
      final convUpdates = <String, ConvBatchUpdate>{};
      final convID = 'si_collect_005';
      final received = <String>[];

      env.syncer.onNewMsg = (msg) => received.add(msg['clientMsgID'] as String);

      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'typing1', sendID: 'u2', recvID: 'test_user_001', seq: 0),
        convID,
        convUpdates,
      );

      expect(received, contains('typing1'));
      expect(convUpdates.containsKey(convID), isFalse);

      await destroyTestEnv(env.db, env.dir);
    });

    test('混合自己和对方消息 - unread 仅计对方', () async {
      final env = await createTestEnv();
      final convUpdates = <String, ConvBatchUpdate>{};
      final convID = 'si_collect_006';
      final t = DateTime.now().millisecondsSinceEpoch;

      env.syncer.collectMessageUpdate(
        makeMsg(clientMsgID: 'other1', sendID: 'u2', recvID: 'test_user_001', seq: 1, sendTime: t),
        convID,
        convUpdates,
      );
      env.syncer.collectMessageUpdate(
        makeMsg(
          clientMsgID: 'self1',
          sendID: 'test_user_001',
          recvID: 'u2',
          seq: 2,
          sendTime: t + 100,
        ),
        convID,
        convUpdates,
      );
      env.syncer.collectMessageUpdate(
        makeMsg(
          clientMsgID: 'other2',
          sendID: 'u2',
          recvID: 'test_user_001',
          seq: 3,
          sendTime: t + 200,
        ),
        convID,
        convUpdates,
      );

      expect(convUpdates[convID]!.newUnreadCount, 2);
      expect(convUpdates[convID]!.maxSeq, 3);

      await destroyTestEnv(env.db, env.dir);
    });
  });

  // =========================================================================
  // 六、applyBatchUpdatesAndNotify — 批量应用会话更新
  // =========================================================================
  group('applyBatchUpdatesAndNotify', () {
    test('新会话创建 - 写入 DB 并触发 onNewConversation', () async {
      final env = await createTestEnv();
      final convID = 'si_apply_001';
      final t = DateTime.now().millisecondsSinceEpoch;

      final newConvIDs = <String>[];
      env.syncer.onNewConversation = (ids) => newConvIDs.addAll(ids);
      env.syncer.onTotalUnreadCountChanged = () {};

      final msg = makeMsg(
        clientMsgID: 'a1',
        sendID: 'u2',
        recvID: 'test_user_001',
        seq: 1,
        sendTime: t,
      );
      final update = ConvBatchUpdate(firstMsg: msg);
      update.latestMsg = msg;
      update.latestMsgSendTime = t;
      update.maxSeq = 1;
      update.newUnreadCount = 1;

      await env.syncer.applyBatchUpdatesAndNotify({convID: update}, {});

      final conv = await env.db.getConversation(convID);
      expect(conv, isNotNull);
      expect(conv!['conversationID'], convID);
      expect(conv['maxSeq'], 1);
      expect(conv['unreadCount'], 1);
      expect(newConvIDs, contains(convID));

      await destroyTestEnv(env.db, env.dir);
    });

    test('已有会话更新 - 累加 unreadCount, 更新 latestMsg', () async {
      final env = await createTestEnv();
      final convID = 'si_apply_002';
      final t = DateTime.now().millisecondsSinceEpoch;

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 5,
        'unreadCount': 3,
        'latestMsgSendTime': t - 5000,
        'latestMsg': jsonEncode(
          makeMsg(clientMsgID: 'old', sendID: 'u2', recvID: 'u1', sendTime: t - 5000),
        ),
      });

      final changedIDs = <String>[];
      env.syncer.onConversationChanged = (ids) => changedIDs.addAll(ids);
      env.syncer.onTotalUnreadCountChanged = () {};

      final msg = makeMsg(
        clientMsgID: 'new_apply',
        sendID: 'u2',
        recvID: 'test_user_001',
        seq: 8,
        sendTime: t,
      );
      final update = ConvBatchUpdate(firstMsg: msg);
      update.latestMsg = msg;
      update.latestMsgSendTime = t;
      update.maxSeq = 8;
      update.newUnreadCount = 2;

      await env.syncer.applyBatchUpdatesAndNotify({convID: update}, {});

      final conv = await env.db.getConversation(convID);
      expect(conv!['maxSeq'], 8);
      expect(conv['unreadCount'], 5); // 3 + 2
      final latestMsg = jsonDecode(conv['latestMsg'] as String);
      expect(latestMsg['clientMsgID'], 'new_apply');
      expect(changedIDs, contains(convID));

      await destroyTestEnv(env.db, env.dir);
    });

    test('已有会话 - 旧消息不覆盖 latestMsg', () async {
      final env = await createTestEnv();
      final convID = 'si_apply_003';
      final t = DateTime.now().millisecondsSinceEpoch;

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 10,
        'unreadCount': 0,
        'latestMsgSendTime': t,
        'latestMsg': jsonEncode(
          makeMsg(clientMsgID: 'newer', sendID: 'u2', recvID: 'u1', sendTime: t),
        ),
      });

      final oldMsg = makeMsg(
        clientMsgID: 'older',
        sendID: 'u2',
        recvID: 'test_user_001',
        seq: 5,
        sendTime: t - 10000,
      );
      final update = ConvBatchUpdate(firstMsg: oldMsg);
      update.latestMsg = oldMsg;
      update.latestMsgSendTime = t - 10000;
      update.maxSeq = 5;
      update.newUnreadCount = 1;

      env.syncer.onConversationChanged = (_) {};
      env.syncer.onTotalUnreadCountChanged = () {};
      await env.syncer.applyBatchUpdatesAndNotify({convID: update}, {});

      final conv = await env.db.getConversation(convID);
      final latestMsg = jsonDecode(conv!['latestMsg'] as String);
      expect(latestMsg['clientMsgID'], 'newer');

      await destroyTestEnv(env.db, env.dir);
    });

    test('多个会话同时更新 - 回调中包含所有变更的 ID', () async {
      final env = await createTestEnv();
      final t = DateTime.now().millisecondsSinceEpoch;

      final newIDs = <String>[];
      env.syncer.onNewConversation = (ids) => newIDs.addAll(ids);
      env.syncer.onTotalUnreadCountChanged = () {};

      final updates = <String, ConvBatchUpdate>{};
      for (var i = 0; i < 3; i++) {
        final convID = 'si_multi_$i';
        final msg = makeMsg(
          clientMsgID: 'mm$i',
          sendID: 'u$i',
          recvID: 'test_user_001',
          seq: i + 1,
          sendTime: t + i * 1000,
        );
        final u = ConvBatchUpdate(firstMsg: msg);
        u.latestMsg = msg;
        u.latestMsgSendTime = t + i * 1000;
        u.maxSeq = i + 1;
        u.newUnreadCount = 1;
        updates[convID] = u;
      }

      await env.syncer.applyBatchUpdatesAndNotify(updates, {});

      expect(newIDs.length, 3);
      expect(newIDs, containsAll(['si_multi_0', 'si_multi_1', 'si_multi_2']));

      await destroyTestEnv(env.db, env.dir);
    });

    test('空 updates 不触发回调', () async {
      final env = await createTestEnv();
      var callbackCalled = false;
      env.syncer.onConversationChanged = (_) => callbackCalled = true;
      env.syncer.onNewConversation = (_) => callbackCalled = true;
      env.syncer.onTotalUnreadCountChanged = () => callbackCalled = true;

      await env.syncer.applyBatchUpdatesAndNotify({}, {});
      expect(callbackCalled, isFalse);

      await destroyTestEnv(env.db, env.dir);
    });
  });

