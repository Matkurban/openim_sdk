    test('已有会话收到新消息 - 更新而非重复创建', () async {
      final env = await createTestEnv();
      final convID = 'si_e2e_existing';
      final t = DateTime.now().millisecondsSinceEpoch;

      await env.db.upsertConversation({
        'conversationID': convID,
        'conversationType': 1,
        'maxSeq': 5,
        'unreadCount': 2,
        'latestMsgSendTime': t - 10000,
        'userID': 'u2',
      });

      final changedIDs = <String>[];
      env.syncer.onConversationChanged = (ids) => changedIDs.addAll(ids);
      env.syncer.onTotalUnreadCountChanged = () {};

      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'exist_new',
                  sendID: 'u2',
                  recvID: 'test_user_001',
                  seq: 6,
                  sendTime: t,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 1));

      final conv = await env.db.getConversation(convID);
      expect(conv!['maxSeq'], 6);
      expect(conv['unreadCount'], 3); // 2 + 1
      expect(changedIDs, contains(convID));

      final all = await env.db.getAllConversations();
      final count = all.where((c) => c['conversationID'] == convID).length;
      expect(count, 1);

      await destroyTestEnv(env.db, env.dir);
    });

    test('SEQ 缺口检测', () async {
      final env = await createTestEnv();
      final convID = 'si_e2e_gap';
      final t = DateTime.now().millisecondsSinceEpoch;

      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'gap1',
                  sendID: 'u2',
                  recvID: 'test_user_001',
                  seq: 5,
                  sendTime: t,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 1));

      var gapDetected = false;
      final sub = Logger('MsgSyncer').onRecord.listen((rec) {
        if (rec.message.contains('SEQ 缺口')) gapDetected = true;
      });

      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'gap2',
                  sendID: 'u2',
                  recvID: 'test_user_001',
                  seq: 20,
                  sendTime: t + 5000,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 2));
      sub.cancel();

      expect(gapDetected, isTrue);

      await destroyTestEnv(env.db, env.dir);
    });

    test('SEQ 连续 - 不触发缺口检测', () async {
      final env = await createTestEnv();
      final convID = 'si_e2e_nogap';
      final t = DateTime.now().millisecondsSinceEpoch;

      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'ng1',
                  sendID: 'u2',
                  recvID: 'test_user_001',
                  seq: 1,
                  sendTime: t,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 1));

      var gapDetected = false;
      final sub = Logger('MsgSyncer').onRecord.listen((rec) {
        if (rec.message.contains('SEQ 缺口')) gapDetected = true;
      });

      env.syncer.handlePushMsg(
        makePushResp({
          'msgs': {
            convID: {
              'msgs': [
                makeMsg(
                  clientMsgID: 'ng2',
                  sendID: 'u2',
                  recvID: 'test_user_001',
                  seq: 2,
                  sendTime: t + 1000,
                ),
              ],
            },
          },
          'notificationMsgs': {},
        }),
      );
      await Future.delayed(const Duration(seconds: 1));
      sub.cancel();

      expect(gapDetected, isFalse);

      await destroyTestEnv(env.db, env.dir);
    });

    test('新会话创建后 enrichNewConversation 补充名称', () async {
      final env = await createTestEnv();
      final convID = 'si_e2e_enrich';
      final t = DateTime.now().millisecondsSinceEpoch;

