// ---------------------------------------------------------------------------
// 测试配置
// ---------------------------------------------------------------------------
const _apiAddr = 'http://115.190.173.31:10002';
const _wsAddr = 'ws://115.190.173.31:10001';
const _chatAddr = 'http://115.190.173.31:10008';

// 三个测试账号
const _phone1 = '13579885143';
const _phone2 = '13579885142';
const _password = '123456m';
const _areaCode = '+86';

// ---------------------------------------------------------------------------
// 辅助函数
// ---------------------------------------------------------------------------

/// 通过 Chat API 登录并返回 {chatToken, userID, imToken}
Future<Map<String, String>> chatLogin(String phone) async {
  final dio = Dio(
    BaseOptions(
      baseUrl: _chatAddr,
      headers: {'operationID': 'test_${DateTime.now().millisecondsSinceEpoch}'},
    ),
  );
  final response = await dio.post(
    '/account/login',
    data: {
      'phoneNumber': phone,
      'password': ImUtils.generateMD5(_password),
      'areaCode': _areaCode,
      'platform': 5,
    },
  );
  final body = response.data as Map<String, dynamic>;
  expect(body['errCode'], 0, reason: '登录失败: ${body['errMsg']}');
  final data = body['data'] as Map<String, dynamic>;
  return {
    'chatToken': data['chatToken'] as String? ?? '',
    'userID': data['userID'] as String? ?? '',
    'imToken': data['imToken'] as String? ?? '',
  };
}

/// 等待异步条件满足（最多 [timeout] 秒）
Future<void> waitFor(
  Future<bool> Function() predicate, {
  int timeout = 15,
  Duration interval = const Duration(milliseconds: 500),
}) async {
  final deadline = DateTime.now().add(Duration(seconds: timeout));
  while (DateTime.now().isBefore(deadline)) {
    if (await predicate()) return;
    await Future.delayed(interval);
  }
  fail('waitFor 超时（${timeout}s）');
}

// ---------------------------------------------------------------------------
// 测试主体
// ---------------------------------------------------------------------------

void main() {
  // 启用日志
  Logger.root.level = Level.INFO;
  Logger.root.onRecord.listen((rec) {
    // ignore: avoid_print
    print('${rec.level.name}: ${rec.loggerName}: ${rec.message}');
  });

  // ------------------------------------------------------------------
  // 一、MsgSyncer 推送消息处理单元测试
  // ------------------------------------------------------------------
  group('MsgSyncer 推送消息处理', () {
    late DatabaseService db;
    late MsgSyncer syncer;
    final testUserID = 'test_user_001';
    late Directory tempDir;

    setUp(() async {
      tempDir = Directory.systemTemp.createTempSync('openim_test_');
      db = DatabaseService();
      await db.init(userID: testUserID, dataDir: tempDir.path);

      // MsgSyncer 需要 WsConnectionManager 和 ImApiService，但单元测试中
      // 我们只测试 push 处理逻辑，所以给它们 stub 实例
      final ws = WsConnectionManager();
      final api = ImApiService();
      syncer = MsgSyncer(ws: ws, db: db, api: api);
      syncer.setLoginUserID(testUserID);
    });

    tearDown(() async {
      await db.close();
      try {
        tempDir.deleteSync(recursive: true);
      } catch (_) {}
    });

    test('处理推送消息后应创建新会话并设置 latestMsg', () async {
      final conversationID = 'si_test_user_001_test_user_002';
      final msgSeq = 1;
      final sendTime = DateTime.now().millisecondsSinceEpoch;

      // 构造推送消息
      final pushPayload = {
        'msgs': {
          conversationID: {
            'msgs': [
              {
                'clientMsgID': 'msg_001',
                'serverMsgID': 'server_msg_001',
                'sendID': 'test_user_002',
                'recvID': testUserID,
                'senderNickname': '测试用户2',
                'senderFaceUrl': 'https://example.com/face.png',
                'sessionType': 1,
                'contentType': 101, // 文本消息
                'content': jsonEncode({'content': '你好'}),
                'seq': msgSeq,
                'sendTime': sendTime,
                'createTime': sendTime,
                'status': 2, // 已发送
                'groupID': '',
              },
            ],
          },
        },
        'notificationMsgs': {},
      };

      // 获取回调
      final newMsgCompleter = Completer<Map<String, dynamic>>();
      final convChangedCompleter = Completer<List<String>>();
      final totalUnreadCompleter = Completer<void>();

      syncer.onNewMsg = (msg) {
        if (!newMsgCompleter.isCompleted) newMsgCompleter.complete(msg);
      };
      syncer.onConversationChanged = (convIDs) {
        if (!convChangedCompleter.isCompleted) convChangedCompleter.complete(convIDs);
      };
      syncer.onTotalUnreadCountChanged = () {
        if (!totalUnreadCompleter.isCompleted) totalUnreadCompleter.complete();
      };

      // 编码为 WS 推送格式并调用 handlePushMsg
      final pushBytes = utf8.encode(jsonEncode(pushPayload));
      final resp = GeneralWsResp(
        reqIdentifier: 2001,
        errCode: 0,
        errMsg: '',
        msgIncr: '',
        operationID: '',
        data: pushBytes,
      );

      syncer.handlePushMsg(resp);

      // 等待新消息回调
      final newMsg = await newMsgCompleter.future.timeout(const Duration(seconds: 5));
      expect(newMsg['clientMsgID'], 'msg_001');
      expect(newMsg['sendID'], 'test_user_002');

      // 等待异步会话更新完成
      await Future.delayed(const Duration(seconds: 1));

      // 验证会话已写入 DB
      final conv = await db.getConversation(conversationID);
      expect(conv, isNotNull, reason: '推送消息后应创建新会话');
      expect(conv!['conversationID'], conversationID);
      expect(conv['maxSeq'], msgSeq);
      expect(conv['unreadCount'], 1, reason: '对方发的消息应计入未读');

      // 验证 latestMsg
      final latestMsgJson = conv['latestMsg'] as String?;
      expect(latestMsgJson, isNotNull);
      final latestMsg = jsonDecode(latestMsgJson!) as Map<String, dynamic>;
      expect(latestMsg['clientMsgID'], 'msg_001');
    });

    test('推送自己发送的消息时不增加未读数', () async {
      final conversationID = 'si_test_user_001_test_user_003';
      final sendTime = DateTime.now().millisecondsSinceEpoch;

      final pushPayload = {
        'msgs': {
          conversationID: {
            'msgs': [
              {
                'clientMsgID': 'msg_self_001',
                'serverMsgID': 'server_msg_self_001',
                'sendID': testUserID, // 自己发出
                'recvID': 'test_user_003',
                'senderNickname': '我自己',
                'sessionType': 1,
                'contentType': 101,
                'content': jsonEncode({'content': '自己发的'}),
                'seq': 1,
                'sendTime': sendTime,
                'createTime': sendTime,
                'status': 2,
                'groupID': '',
              },
            ],
          },
        },
        'notificationMsgs': {},
      };

      final pushBytes = utf8.encode(jsonEncode(pushPayload));
      syncer.handlePushMsg(
        GeneralWsResp(
          reqIdentifier: 2001,
          errCode: 0,
          errMsg: '',
          msgIncr: '',
          operationID: '',
          data: pushBytes,
        ),
      );

      await Future.delayed(const Duration(seconds: 1));

      final conv = await db.getConversation(conversationID);
      expect(conv, isNotNull);
      expect(conv!['unreadCount'], 0, reason: '自己发送的消息不应计入未读');
    });

    test('多条推送消息应累加未读数并使用最新消息作为 latestMsg', () async {
      final conversationID = 'si_test_user_001_test_user_004';
      final baseTime = DateTime.now().millisecondsSinceEpoch;

      final pushPayload = {
        'msgs': {
          conversationID: {
            'msgs': [
              {
                'clientMsgID': 'msg_multi_001',
                'serverMsgID': 'srv_multi_001',
                'sendID': 'test_user_004',
                'recvID': testUserID,
                'senderNickname': '用户4',
                'sessionType': 1,
                'contentType': 101,
                'content': jsonEncode({'content': '第一条消息'}),
                'seq': 1,
                'sendTime': baseTime,
                'createTime': baseTime,
                'status': 2,
                'groupID': '',
              },
              {
                'clientMsgID': 'msg_multi_002',
                'serverMsgID': 'srv_multi_002',
                'sendID': 'test_user_004',
                'recvID': testUserID,
                'senderNickname': '用户4',
                'sessionType': 1,
                'contentType': 101,
                'content': jsonEncode({'content': '第二条消息'}),
                'seq': 2,
                'sendTime': baseTime + 1000,
                'createTime': baseTime + 1000,
                'status': 2,
                'groupID': '',
              },
              {
                'clientMsgID': 'msg_multi_003',
                'serverMsgID': 'srv_multi_003',
                'sendID': 'test_user_004',
                'recvID': testUserID,
                'senderNickname': '用户4',
                'sessionType': 1,
                'contentType': 101,
                'content': jsonEncode({'content': '第三条消息'}),
                'seq': 3,
                'sendTime': baseTime + 2000,
                'createTime': baseTime + 2000,
                'status': 2,
                'groupID': '',
              },
            ],
          },
        },
        'notificationMsgs': {},
      };

      syncer.handlePushMsg(
        GeneralWsResp(
          reqIdentifier: 2001,
          errCode: 0,
          errMsg: '',
          msgIncr: '',
          operationID: '',
          data: utf8.encode(jsonEncode(pushPayload)),
        ),
      );

      await Future.delayed(const Duration(seconds: 2));

      final conv = await db.getConversation(conversationID);
      expect(conv, isNotNull, reason: '处理多条消息后应创建会话');
      expect(conv!['maxSeq'], 3, reason: '应记录最大 seq');
      expect(conv['unreadCount'], 3, reason: '3条对方消息应累计3个未读');

      // latestMsg 应该是 sendTime 最新的那条（第三条）
      final latestMsg = jsonDecode(conv['latestMsg'] as String) as Map<String, dynamic>;
      expect(latestMsg['clientMsgID'], 'msg_multi_003');
    });

    test('通知消息不应存入 chatLog 但应更新 maxSeq', () async {
      final conversationID = 'si_test_user_001_test_user_005';
      final sendTime = DateTime.now().millisecondsSinceEpoch;

      final pushPayload = {
        'msgs': {
          conversationID: {
            'msgs': [
              {
                'clientMsgID': 'notification_msg_001',
                'serverMsgID': 'srv_notification_001',
                'sendID': 'system',
                'recvID': testUserID,
                'sessionType': 1,
                'contentType': 1201, // 好友申请通过通知
                'content': '{}',
                'seq': 5,
                'sendTime': sendTime,
                'createTime': sendTime,
                'status': 2,
                'groupID': '',
              },
            ],
          },
        },
        'notificationMsgs': {},
      };

      syncer.handlePushMsg(
        GeneralWsResp(
          reqIdentifier: 2001,
          errCode: 0,
          errMsg: '',
          msgIncr: '',
          operationID: '',
          data: utf8.encode(jsonEncode(pushPayload)),
        ),
      );

      await Future.delayed(const Duration(seconds: 1));

      // maxSeq 应该被更新（即使是通知消息）
      // 通知消息不创建会话（通过 updateConversation 处理，但会话不存在时 update 不会创建新记录）
      // 这是预期行为——通知消息不应创建会话
    });

    test('SEQ 缺口检测 - 消息不连续时应标记需要同步', () async {
      final conversationID = 'si_test_user_001_test_user_006';
      final sendTime = DateTime.now().millisecondsSinceEpoch;

      // 先模拟本地已有 seq=5 的状态
      await db.upsertConversation({
        'conversationID': conversationID,
        'conversationType': 1,
        'maxSeq': 5,
        'unreadCount': 0,
        'latestMsgSendTime': sendTime - 10000,
      });

      // 手动设置同步 seq
      // MsgSyncer 内部的 _syncedMaxSeqs 通过 push 处理自动维护
      // 先推一条 seq=6 建立追踪
      syncer.handlePushMsg(
        GeneralWsResp(
          reqIdentifier: 2001,
          errCode: 0,
          errMsg: '',
          msgIncr: '',
          operationID: '',
          data: utf8.encode(
            jsonEncode({
              'msgs': {
                conversationID: {
                  'msgs': [
                    {
                      'clientMsgID': 'msg_gap_006',
                      'serverMsgID': 'srv_gap_006',
                      'sendID': 'test_user_006',
                      'recvID': testUserID,
                      'sessionType': 1,
                      'contentType': 101,
                      'content': jsonEncode({'content': 'seq6'}),
                      'seq': 6,
                      'sendTime': sendTime,
                      'createTime': sendTime,
                      'status': 2,
                      'groupID': '',
                    },
                  ],
                },
              },
              'notificationMsgs': {},
            }),
          ),
        ),
      );

      await Future.delayed(const Duration(seconds: 1));

      // 现在推 seq=10（跳过 7,8,9 → 有缺口）
      // 由于本地 maxSeq=6，push min=10 > local+1=7，会触发缺口同步
      var gapDetected = false;
      // 监听日志来验证缺口检测
      final sub = Logger('MsgSyncer').onRecord.listen((rec) {
        if (rec.message.contains('SEQ 缺口') || rec.message.contains('缺口同步')) {
          gapDetected = true;
        }
      });

      syncer.handlePushMsg(
        GeneralWsResp(
          reqIdentifier: 2001,
          errCode: 0,
          errMsg: '',
          msgIncr: '',
          operationID: '',
          data: utf8.encode(
            jsonEncode({
              'msgs': {
                conversationID: {
                  'msgs': [
                    {
                      'clientMsgID': 'msg_gap_010',
                      'serverMsgID': 'srv_gap_010',
                      'sendID': 'test_user_006',
                      'recvID': testUserID,
                      'sessionType': 1,
                      'contentType': 101,
                      'content': jsonEncode({'content': 'seq10'}),
                      'seq': 10,
                      'sendTime': sendTime + 5000,
                      'createTime': sendTime + 5000,
                      'status': 2,
                      'groupID': '',
                    },
                  ],
                },
              },
              'notificationMsgs': {},
            }),
          ),
        ),
      );

      await Future.delayed(const Duration(seconds: 2));
      sub.cancel();

      expect(gapDetected, isTrue, reason: '应检测到 SEQ 缺口 (local=6, push=10)');
    });
  });

  // ------------------------------------------------------------------
  // 二、完整集成测试（连接真实服务器）
  // ------------------------------------------------------------------
  group('集成测试 - 真实服务器', () {
    // 确保每个 test 前 GetIt 被清理
    setUp(() async {
      if (GetIt.instance.isRegistered<InitConfig>()) {
        await GetIt.instance.reset();
      }
    });

    tearDown(() async {
      try {
        await OpenIM.iMManager.logout();
      } catch (_) {}
      try {
        await GetIt.instance.reset();
      } catch (_) {}
    });

    test('登录并完成初始会话同步', () async {
      // 1. 初始化 SDK
      final syncStarted = Completer<bool>();
      final syncFinished = Completer<bool>();

      final initOk = await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () => print('[连接] 正在连接...'),
          onConnectSuccess: () => print('[连接] 连接成功'),
          onConnectFailed: (code, msg) => print('[连接] 连接失败: $code $msg'),
          onKickedOffline: () => print('[连接] 被踢下线'),
          onUserTokenExpired: () => print('[连接] Token 过期'),
          onUserTokenInvalid: () => print('[连接] Token 无效'),
        ),
      );
      expect(initOk, isTrue, reason: 'SDK 初始化应成功');

      // 设置会话监听
      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerStart: (reinstalled) {
          print('[同步] 开始: reinstalled=$reinstalled');
          if (!syncStarted.isCompleted) syncStarted.complete(true);
        },
        onSyncServerProgress: (progress) {
          print('[同步] 进度: $progress%');
        },
        onSyncServerFinish: (reinstalled) {
          print('[同步] 完成: reinstalled=$reinstalled');
          if (!syncFinished.isCompleted) syncFinished.complete(true);
        },
        onSyncServerFailed: (reinstalled) {
          print('[同步] 失败: reinstalled=$reinstalled');
          if (!syncFinished.isCompleted) syncFinished.complete(false);
        },
        onConversationChanged: (list) {
          print('[会话] 变更: ${list.length} 个');
          for (final c in list) {
            print('  - ${c.conversationID}: ${c.showName}, unread=${c.unreadCount}');
          }
        },
        onNewConversation: (list) {
          print('[会话] 新增: ${list.length} 个');
        },
        onTotalUnreadMessageCountChanged: (count) {
          print('[会话] 总未读: $count');
        },
      );

      // 2. 通过 Chat API 获取 token
      HttpClient().init(baseUrl: _apiAddr);
      final loginResult = await chatLogin(_phone1);
      expect(loginResult['imToken'], isNotEmpty, reason: '应获取到 imToken');
      expect(loginResult['userID'], isNotEmpty, reason: '应获取到 userID');
      print('[登录] userID=${loginResult['userID']}');

      // 3. 登录 IM SDK
      final userInfo = await OpenIM.iMManager.login(
        userID: loginResult['userID']!,
        token: loginResult['imToken']!,
      );
      expect(userInfo, isNotNull, reason: '登录应返回用户信息');
      print('[登录] 用户: ${userInfo?.nickname ?? '未知'}');

      // 4. 等待同步完成
      await syncFinished.future.timeout(
        const Duration(seconds: 30),
        onTimeout: () {
          print('[同步] 超时，继续验证');
          return false;
        },
      );

      // 5. 获取并验证会话列表
      final conversations = await OpenIM.iMManager.conversationManager.getAllConversationList();
      print('[会话] 获取到 ${conversations.length} 个会话');
      for (final conv in conversations) {
        final hasLatest = conv.latestMsg != null;
        print(
          '  - ${conv.conversationID}: '
          'showName=${conv.showName}, '
          'type=${conv.conversationType}, '
          'unread=${conv.unreadCount}, '
          'maxSeq=?, '
          'hasLatestMsg=$hasLatest, '
          'latestMsgSendTime=${conv.latestMsgSendTime}',
        );
      }

      // 验证：至少应有一些会话
      // （如果之前有聊天记录）
      if (conversations.isNotEmpty) {
        // 每个会话应有 conversationID
        for (final conv in conversations) {
          expect(conv.conversationID, isNotEmpty, reason: '每个会话的 conversationID 不应为空');
        }

        // 检查是否有 latestMsg
        final withLatestMsg = conversations.where((c) => c.latestMsg != null).length;
        print('[验证] ${conversations.length} 个会话中 $withLatestMsg 个有 latestMsg');
      }
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('发送消息后会话列表应更新', () async {
      // 1. 初始化 + 登录用户1
      final syncFinished = Completer<bool>();
      final convChanged = Completer<List<ConversationInfo>>();

      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (code, msg) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );

      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(false);
        },
        onConversationChanged: (list) {
          if (!convChanged.isCompleted && list.isNotEmpty) {
            convChanged.complete(list);
          }
        },
      );

      HttpClient().init(baseUrl: _apiAddr);
      final login1 = await chatLogin(_phone1);
      await OpenIM.iMManager.login(userID: login1['userID']!, token: login1['imToken']!);

      // 等待初始同步
      await syncFinished.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      // 2. 通过 SDK 发送消息给用户2
      final login2 = await chatLogin(_phone2);
      final user2ID = login2['userID']!;
      print('[测试] 用户2 ID: $user2ID');

      // 获取发送消息前的会话状态
      final convsBefore = await OpenIM.iMManager.conversationManager.getAllConversationList();
      print('[测试] 发送前会话数: ${convsBefore.length}');

      // 通过 SDK 的 MessageManager 创建并发送文本消息（走 WS）
      try {
        final textMsg = OpenIM.iMManager.messageManager.createTextMessage(
          text: '集成测试消息 ${DateTime.now()}',
        );
        print('[测试] 创建消息: ${textMsg.clientMsgID}');
        final sentMsg = await OpenIM.iMManager.messageManager.sendMessage(
          message: textMsg,
          userID: user2ID,
          offlinePushInfo: OfflinePushInfo(title: '新消息', desc: '你收到一条消息'),
        );
        print('[测试] 消息发送成功: seq=${sentMsg.seq}');

        // 等待会话变更通知
        try {
          final changedConvs = await convChanged.future.timeout(const Duration(seconds: 15));
          print('[测试] 收到会话变更: ${changedConvs.length} 个');
          for (final c in changedConvs) {
            print(
              '  - ${c.conversationID}: unread=${c.unreadCount}, '
              'latestMsg=${c.latestMsg?.contentType}',
            );
          }
        } catch (_) {
          print('[测试] 等待会话变更超时');
        }
      } catch (e) {
        print('[测试] 消息发送失败（WS 可能未完全就绪）: $e');
      }

      // 验证会话列表
      final convsAfter = await OpenIM.iMManager.conversationManager.getAllConversationList();
      print('[测试] 当前会话数: ${convsAfter.length}');
      for (final c in convsAfter) {
        print(
          '  - ${c.conversationID}: showName=${c.showName}, '
          'unread=${c.unreadCount}, hasLatestMsg=${c.latestMsg != null}',
        );
      }
      expect(convsAfter, isNotEmpty, reason: '应至少有一些会话');
    }, timeout: const Timeout(Duration(minutes: 2)));

    test('未读总数应正确反映', () async {
      final syncFinished = Completer<bool>();

      await OpenIM.iMManager.init(
        config: const InitConfig(apiAddr: _apiAddr, wsAddr: _wsAddr, platformID: 5),
        listener: OnConnectListener(
          onConnecting: () {},
          onConnectSuccess: () {},
          onConnectFailed: (code, msg) {},
          onKickedOffline: () {},
          onUserTokenExpired: () {},
          onUserTokenInvalid: () {},
        ),
      );

      OpenIM.iMManager.conversationManager.listener = OnConversationListener(
        onSyncServerFinish: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(true);
        },
        onSyncServerFailed: (_) {
          if (!syncFinished.isCompleted) syncFinished.complete(false);
        },
        onTotalUnreadMessageCountChanged: (count) {
          print('[未读] 总未读变更: $count');
        },
      );

      HttpClient().init(baseUrl: _apiAddr);
      final loginResult = await chatLogin(_phone1);
      await OpenIM.iMManager.login(userID: loginResult['userID']!, token: loginResult['imToken']!);

      // 等待同步完成
      await syncFinished.future.timeout(const Duration(seconds: 30), onTimeout: () => false);

      // 获取未读总数
      final count = await OpenIM.iMManager.conversationManager.getTotalUnreadMsgCount();
      print('[验证] API 返回未读总数: $count');

      // 验证会话列表中未读数的总和
      final convs = await OpenIM.iMManager.conversationManager.getAllConversationList();
      int sumUnread = 0;
      for (final c in convs) {
        sumUnread += c.unreadCount;
      }
      print('[验证] 会话列表未读总和: $sumUnread, DB 总未读: $count');

      // 两种方式获取的未读数应一致
      expect(count, sumUnread, reason: 'DB 总未读数应等于所有会话未读数之和');
    }, timeout: const Timeout(Duration(minutes: 2)));
  });

  // ------------------------------------------------------------------
  // 三、WebSocket 消息接收验证
  // ------------------------------------------------------------------
  group('WebSocket 消息处理验证', () {
    test('GeneralWsResp 解析验证', () {
      // 测试 WS 响应解析
      final testData = utf8.encode(jsonEncode({'key': 'value'}));
      final resp = GeneralWsResp(
        reqIdentifier: 2001,
        errCode: 0,
        errMsg: '',
        msgIncr: 'test_incr',
        operationID: 'op_test',
        data: testData,
      );

      expect(resp.reqIdentifier, 2001);
      expect(resp.errCode, 0);
      expect(resp.msgIncr, 'test_incr');

      // 解析 data
      final decoded = jsonDecode(utf8.decode(resp.data)) as Map<String, dynamic>;
      expect(decoded['key'], 'value');
    });

    test('推送消息格式 - msgs 按 conversationID 分组', () {
      // 验证推送消息的结构符合预期
      final pushPayload = {
        'msgs': {
          'si_user1_user2': {
            'msgs': [
              {'clientMsgID': 'msg1', 'seq': 1, 'contentType': 101},
              {'clientMsgID': 'msg2', 'seq': 2, 'contentType': 101},
            ],
          },
          'sg_group1': {
            'msgs': [
              {'clientMsgID': 'msg3', 'seq': 5, 'contentType': 101},
            ],
          },
        },
        'notificationMsgs': {
          'si_user1_user2': {
            'msgs': [
              {'clientMsgID': 'notif1', 'seq': 3, 'contentType': 1300},
            ],
          },
        },
      };

      final encoded = jsonEncode(pushPayload);
      final decoded = jsonDecode(encoded) as Map<String, dynamic>;

      final msgs = decoded['msgs'] as Map<String, dynamic>;
      expect(msgs.keys, contains('si_user1_user2'));
      expect(msgs.keys, contains('sg_group1'));

      final convMsgs = msgs['si_user1_user2'] as Map<String, dynamic>;
      final msgList = convMsgs['msgs'] as List;
      expect(msgList.length, 2);

      final notificationMsgs = decoded['notificationMsgs'] as Map<String, dynamic>;
      expect(notificationMsgs.keys, contains('si_user1_user2'));
    });
  });
}
