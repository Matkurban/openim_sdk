import 'dart:convert';

import 'package:logging/logging.dart';
import 'package:tostore/tostore.dart';

import 'db_schema.dart';

/// 数据库服务层
/// 封装 Tostore 操作，提供统一的本地数据库访问接口。
/// 对应 Go SDK 中 pkg/db/ 下的数据库接口抽象。
class DatabaseService {
  static final Logger _log = Logger('DatabaseService');

  ToStore? _db;
  String? _currentUserID;

  /// 获取数据库实例，未初始化时抛出异常
  ToStore get db {
    if (_db == null) {
      throw StateError('数据库未初始化，请先调用 init()');
    }
    return _db!;
  }

  /// 当前登录用户ID
  String get currentUserID {
    if (_currentUserID == null) {
      throw StateError('用户未登录');
    }
    return _currentUserID!;
  }

  /// 数据库是否已初始化
  bool get isInitialized => _db != null;

  /// 初始化数据库
  /// [userID] 用户ID，用于数据空间隔离
  /// [dataDir] 数据存储目录
  Future<void> init({required String userID, String? dataDir}) async {
    _currentUserID = userID;
    _db = await ToStore.open(
      dbPath: dataDir,
      dbName: 'openim_$userID',
      schemas: DbSchema.allSchemas,
    );
    _log.info('数据库初始化完成: userID=$userID');
  }

  /// 关闭数据库
  Future<void> close() async {
    await _db?.close();
    _db = null;
    _currentUserID = null;
    _log.info('数据库已关闭');
  }

  // ---------------------------------------------------------------------------
  // 通用 CRUD 操作
  // ---------------------------------------------------------------------------

  /// 插入一条记录
  Future<DbResult> insert(String table, Map<String, dynamic> data) {
    return db.insert(table, data);
  }

  /// 批量插入记录
  Future<DbResult> batchInsert(String table, List<Map<String, dynamic>> dataList) {
    return db.batchInsert(table, dataList);
  }

  /// 插入或更新记录（upsert）
  Future<DbResult> upsert(String table, Map<String, dynamic> data) {
    return db.upsert(table, data);
  }

  /// 批量插入或更新记录
  Future<DbResult> batchUpsert(String table, List<Map<String, dynamic>> dataList) {
    return db.batchUpsert(table, dataList);
  }

  /// 根据主键查询单条记录
  Future<Map<String, dynamic>?> queryByPrimaryKey(String table, dynamic pk) async {
    final results = await db.query(table).where('', '=', pk).go();
    return results.isEmpty ? null : results.first;
  }

  /// 查询表中所有记录
  Future<List<Map<String, dynamic>>> queryAll(String table) {
    return db.query(table).go();
  }

  /// 根据条件删除记录
  Future<void> deleteByPrimaryKey(String table, String pkField, dynamic pkValue) async {
    await db.delete(table).where(pkField, '=', pkValue).go();
  }

  /// 在事务中执行操作
  Future<TransactionResult> transaction(Future<void> Function() action) {
    return db.transaction(action);
  }

  // ---------------------------------------------------------------------------
  // User 操作 - 对应 Go SDK UserModel
  // ---------------------------------------------------------------------------

  /// 插入或更新本地用户信息
  Future<void> insertOrUpdateUser(Map<String, dynamic> userData) async {
    await db.upsert(DbTableName.localUser, userData);
  }

  /// 获取当前登录用户信息
  Future<Map<String, dynamic>?> getLoginUser() async {
    final results = await db.query(DbTableName.localUser).where('userID', '=', currentUserID).go();
    return results.isEmpty ? null : results.first;
  }

  /// 批量获取用户信息
  Future<List<Map<String, dynamic>>> getUsersByIDs(List<String> userIDs) async {
    if (userIDs.isEmpty) return [];
    final results = <Map<String, dynamic>>[];
    for (final id in userIDs) {
      final rows = await db.query(DbTableName.localUser).where('userID', '=', id).go();
      results.addAll(rows);
    }
    return results;
  }

  // ---------------------------------------------------------------------------
  // Friend 操作 - 对应 Go SDK FriendModel
  // ---------------------------------------------------------------------------

  /// 插入或更新好友
  Future<void> upsertFriend(Map<String, dynamic> friendData) async {
    await db.upsert(DbTableName.localFriend, friendData);
  }

  /// 获取所有好友列表
  Future<List<Map<String, dynamic>>> getAllFriends() {
    return db.query(DbTableName.localFriend).where('ownerUserID', '=', currentUserID).go();
  }

  /// 分页获取好友列表
  Future<List<Map<String, dynamic>>> getFriendsPage(int offset, int count) {
    return db
        .query(DbTableName.localFriend)
        .where('ownerUserID', '=', currentUserID)
        .limit(count)
        .offset(offset)
        .go();
  }

  /// 根据好友用户ID获取好友信息
  Future<Map<String, dynamic>?> getFriendByUserID(String friendUserID) async {
    final results = await db
        .query(DbTableName.localFriend)
        .where('friendUserID', '=', friendUserID)
        .go();
    return results.isEmpty ? null : results.first;
  }

  /// 删除好友
  Future<void> deleteFriend(String friendUserID) async {
    await db.delete(DbTableName.localFriend).where('friendUserID', '=', friendUserID).go();
  }

  /// 搜索好友（按昵称或备注模糊匹配）
  Future<List<Map<String, dynamic>>> searchFriends(String keyword) async {
    if (keyword.isEmpty) return [];
    final all = await getAllFriends();
    final lowerKeyword = keyword.toLowerCase();
    return all.where((f) {
      final nickname = (f['nickname'] as String?)?.toLowerCase() ?? '';
      final remark = (f['remark'] as String?)?.toLowerCase() ?? '';
      return nickname.contains(lowerKeyword) || remark.contains(lowerKeyword);
    }).toList();
  }

  // ---------------------------------------------------------------------------
  // FriendRequest 操作
  // ---------------------------------------------------------------------------

  /// 插入或更新好友申请
  Future<void> upsertFriendRequest(Map<String, dynamic> data) async {
    await db.upsert(DbTableName.localFriendRequest, data);
  }

  /// 获取收到的好友申请列表
  Future<List<Map<String, dynamic>>> getFriendRequestsAsRecipient({
    int offset = 0,
    int count = 40,
  }) {
    return db
        .query(DbTableName.localFriendRequest)
        .where('toUserID', '=', currentUserID)
        .limit(count)
        .offset(offset)
        .go();
  }

  /// 获取已发送的好友申请列表
  Future<List<Map<String, dynamic>>> getFriendRequestsAsApplicant({
    int offset = 0,
    int count = 40,
  }) {
    return db
        .query(DbTableName.localFriendRequest)
        .where('fromUserID', '=', currentUserID)
        .limit(count)
        .offset(offset)
        .go();
  }

  // ---------------------------------------------------------------------------
  // Black 操作 - 对应 Go SDK FriendModel(黑名单部分)
  // ---------------------------------------------------------------------------

  /// 插入黑名单
  Future<void> insertBlack(Map<String, dynamic> data) async {
    await db.upsert(DbTableName.localBlack, data);
  }

  /// 获取黑名单列表
  Future<List<Map<String, dynamic>>> getBlackList() {
    return db.query(DbTableName.localBlack).where('ownerUserID', '=', currentUserID).go();
  }

  /// 移除黑名单
  Future<void> removeBlack(String blockUserID) async {
    final all = await db
        .query(DbTableName.localBlack)
        .where('ownerUserID', '=', currentUserID)
        .go();
    for (final row in all) {
      if (row['blockUserID'] == blockUserID) {
        await db.delete(DbTableName.localBlack).where('ownerUserID', '=', currentUserID).go();
        break;
      }
    }
  }

  // ---------------------------------------------------------------------------
  // Group 操作 - 对应 Go SDK GroupModel
  // ---------------------------------------------------------------------------

  /// 插入或更新群组
  Future<void> upsertGroup(Map<String, dynamic> data) async {
    await db.upsert(DbTableName.localGroup, data);
  }

  /// 批量插入或更新群组
  Future<void> batchUpsertGroups(List<Map<String, dynamic>> dataList) async {
    if (dataList.isEmpty) return;
    await db.batchUpsert(DbTableName.localGroup, dataList);
  }

  /// 获取已加入的群组列表
  Future<List<Map<String, dynamic>>> getJoinedGroupList() {
    return db.query(DbTableName.localGroup).go();
  }

  /// 分页获取已加入的群组列表
  Future<List<Map<String, dynamic>>> getJoinedGroupListPage(int offset, int count) {
    return db.query(DbTableName.localGroup).limit(count).offset(offset).go();
  }

  /// 根据群组ID获取群组信息
  Future<Map<String, dynamic>?> getGroupByID(String groupID) async {
    final results = await db.query(DbTableName.localGroup).where('groupID', '=', groupID).go();
    return results.isEmpty ? null : results.first;
  }

  /// 根据群组ID列表获取群组信息
  Future<List<Map<String, dynamic>>> getGroupsByIDs(List<String> groupIDs) async {
    if (groupIDs.isEmpty) return [];
    final results = <Map<String, dynamic>>[];
    for (final id in groupIDs) {
      final rows = await db.query(DbTableName.localGroup).where('groupID', '=', id).go();
      results.addAll(rows);
    }
    return results;
  }

  /// 删除群组
  Future<void> deleteGroup(String groupID) async {
    await db.delete(DbTableName.localGroup).where('groupID', '=', groupID).go();
  }

  /// 搜索群组
  Future<List<Map<String, dynamic>>> searchGroups(String keyword) async {
    if (keyword.isEmpty) return [];
    final all = await getJoinedGroupList();
    final lowerKeyword = keyword.toLowerCase();
    return all.where((g) {
      final name = (g['groupName'] as String?)?.toLowerCase() ?? '';
      return name.contains(lowerKeyword);
    }).toList();
  }

  // ---------------------------------------------------------------------------
  // GroupMember 操作
  // ---------------------------------------------------------------------------

  /// 插入或更新群成员
  Future<void> upsertGroupMember(Map<String, dynamic> data) async {
    await db.upsert(DbTableName.localGroupMember, data);
  }

  /// 批量插入或更新群成员
  Future<void> batchUpsertGroupMembers(List<Map<String, dynamic>> dataList) async {
    if (dataList.isEmpty) return;
    await db.batchUpsert(DbTableName.localGroupMember, dataList);
  }

  /// 获取群成员列表
  Future<List<Map<String, dynamic>>> getGroupMembers(String groupID) {
    return db.query(DbTableName.localGroupMember).where('groupID', '=', groupID).go();
  }

  /// 分页获取群成员列表
  Future<List<Map<String, dynamic>>> getGroupMembersPage(
    String groupID, {
    int offset = 0,
    int count = 40,
    int? filter,
  }) async {
    var query = db.query(DbTableName.localGroupMember).where('groupID', '=', groupID);
    if (filter != null && filter > 0) {
      query = query.where('roleLevel', '=', filter);
    }
    return query.limit(count).offset(offset).go();
  }

  /// 获取群组 Owner 和 Admin
  Future<List<Map<String, dynamic>>> getGroupOwnerAndAdmin(String groupID) async {
    final members = await getGroupMembers(groupID);
    return members.where((m) {
      final role = m['roleLevel'] as int?;
      return role == 60 || role == 100; // admin=60, owner=100
    }).toList();
  }

  /// 获取指定群成员信息
  Future<Map<String, dynamic>?> getGroupMember(String groupID, String userID) async {
    final results = await db
        .query(DbTableName.localGroupMember)
        .where('groupID', '=', groupID)
        .where('userID', '=', userID)
        .go();
    return results.isEmpty ? null : results.first;
  }

  /// 删除群成员
  Future<void> deleteGroupMember(String groupID, String userID) async {
    await db
        .delete(DbTableName.localGroupMember)
        .where('groupID', '=', groupID)
        .where('userID', '=', userID)
        .go();
  }

  /// 删除群组的所有成员
  Future<void> deleteGroupAllMembers(String groupID) async {
    await db.delete(DbTableName.localGroupMember).where('groupID', '=', groupID).go();
  }

  /// 搜索群成员
  Future<List<Map<String, dynamic>>> searchGroupMembers(String groupID, String keyword) async {
    if (keyword.isEmpty) return [];
    final members = await getGroupMembers(groupID);
    final lowerKeyword = keyword.toLowerCase();
    return members.where((m) {
      final nickname = (m['nickname'] as String?)?.toLowerCase() ?? '';
      final userID = (m['userID'] as String?)?.toLowerCase() ?? '';
      return nickname.contains(lowerKeyword) || userID.contains(lowerKeyword);
    }).toList();
  }

  // ---------------------------------------------------------------------------
  // GroupRequest 操作
  // ---------------------------------------------------------------------------

  /// 插入或更新群申请
  Future<void> upsertGroupRequest(Map<String, dynamic> data) async {
    await db.upsert(DbTableName.localGroupRequest, data);
  }

  /// 获取作为接收者的群申请列表
  Future<List<Map<String, dynamic>>> getGroupRequestsAsRecipient({
    int offset = 0,
    int count = 40,
  }) async {
    // 查找当前用户是群主或管理员的群组ID
    final adminGroups = await db
        .query(DbTableName.localGroupMember)
        .where('userID', '=', currentUserID)
        .go();
    final myGroupIDs = adminGroups
        .where((m) {
          final role = m['roleLevel'] as int?;
          return role == 60 || role == 100;
        })
        .map((m) => m['groupID'] as String)
        .toList();

    if (myGroupIDs.isEmpty) return [];

    final all = await db.query(DbTableName.localGroupRequest).go();
    return all.where((r) => myGroupIDs.contains(r['groupID'])).skip(offset).take(count).toList();
  }

  /// 获取作为申请者的群申请列表
  Future<List<Map<String, dynamic>>> getGroupRequestsAsApplicant({int offset = 0, int count = 40}) {
    return db
        .query(DbTableName.localGroupRequest)
        .where('userID', '=', currentUserID)
        .limit(count)
        .offset(offset)
        .go();
  }

  // ---------------------------------------------------------------------------
  // Conversation 操作 - 对应 Go SDK ConversationModel
  // ---------------------------------------------------------------------------

  /// 插入或更新会话
  Future<void> upsertConversation(Map<String, dynamic> data) async {
    await db.upsert(DbTableName.localConversation, data);
  }

  /// 批量插入或更新会话
  Future<void> batchUpsertConversations(List<Map<String, dynamic>> dataList) async {
    if (dataList.isEmpty) return;
    await db.batchUpsert(DbTableName.localConversation, dataList);
  }

  /// 获取所有会话列表
  Future<List<Map<String, dynamic>>> getAllConversations() {
    return db.query(DbTableName.localConversation).go();
  }

  /// 分页获取会话列表
  Future<List<Map<String, dynamic>>> getConversationsPage(int offset, int count) {
    return db.query(DbTableName.localConversation).limit(count).offset(offset).go();
  }

  /// 根据会话ID获取单个会话
  Future<Map<String, dynamic>?> getConversation(String conversationID) async {
    final results = await db
        .query(DbTableName.localConversation)
        .where('conversationID', '=', conversationID)
        .go();
    return results.isEmpty ? null : results.first;
  }

  /// 根据会话ID列表获取多个会话
  Future<List<Map<String, dynamic>>> getMultipleConversations(List<String> conversationIDs) async {
    if (conversationIDs.isEmpty) return [];
    final results = <Map<String, dynamic>>[];
    for (final id in conversationIDs) {
      final rows = await db
          .query(DbTableName.localConversation)
          .where('conversationID', '=', id)
          .go();
      results.addAll(rows);
    }
    return results;
  }

  /// 删除会话
  Future<void> deleteConversation(String conversationID) async {
    await db
        .delete(DbTableName.localConversation)
        .where('conversationID', '=', conversationID)
        .go();
  }

  /// 获取未读消息总数
  Future<int> getTotalUnreadCount() async {
    final conversations = await getAllConversations();
    int total = 0;
    for (final c in conversations) {
      total += (c['unreadCount'] as int?) ?? 0;
    }
    return total;
  }

  /// 更新会话草稿
  Future<void> setConversationDraft(String conversationID, String draftText) async {
    await db
        .update(DbTableName.localConversation, {
          'draftText': draftText,
          'draftTextTime': DateTime.now().millisecondsSinceEpoch,
        })
        .where('conversationID', '=', conversationID)
        .go();
  }

  /// 清空会话未读数
  Future<void> clearConversationUnreadCount(String conversationID) async {
    await db
        .update(DbTableName.localConversation, {'unreadCount': 0})
        .where('conversationID', '=', conversationID)
        .go();
  }

  /// 搜索会话
  Future<List<Map<String, dynamic>>> searchConversations(String keyword) async {
    if (keyword.isEmpty) return [];
    final all = await getAllConversations();
    final lowerKeyword = keyword.toLowerCase();
    return all.where((c) {
      final showName = (c['showName'] as String?)?.toLowerCase() ?? '';
      return showName.contains(lowerKeyword);
    }).toList();
  }

  // ---------------------------------------------------------------------------
  // ChatLog (Message) 操作 - 对应 Go SDK MessageModel
  // ---------------------------------------------------------------------------

  /// 插入消息
  Future<void> insertMessage(Map<String, dynamic> msgData) async {
    await db.upsert(DbTableName.localChatLog, msgData);
  }

  /// 批量插入消息
  Future<void> batchInsertMessages(List<Map<String, dynamic>> msgList) async {
    if (msgList.isEmpty) return;
    await db.batchUpsert(DbTableName.localChatLog, msgList);
  }

  /// 根据 clientMsgID 获取消息
  Future<Map<String, dynamic>?> getMessage(String clientMsgID) async {
    final results = await db
        .query(DbTableName.localChatLog)
        .where('clientMsgID', '=', clientMsgID)
        .go();
    return results.isEmpty ? null : results.first;
  }

  /// 获取会话的历史消息（按发送时间倒序）
  /// [conversationID] 需要解析出 sessionType 和 sourceID
  /// [startTime] 起始时间戳（毫秒），0 表示从最新开始
  /// [count] 获取条数
  Future<List<Map<String, dynamic>>> getHistoryMessages({
    required String sendID,
    required String recvID,
    String? groupID,
    required int sessionType,
    int startTime = 0,
    int count = 20,
  }) async {
    var query = db.query(DbTableName.localChatLog).where('sessionType', '=', sessionType);

    if (groupID != null && groupID.isNotEmpty) {
      query = query.where('groupID', '=', groupID);
    } else {
      // 单聊：sendID/recvID 互换都要查
      // 使用全量查询后再过滤
    }

    if (startTime > 0) {
      query = query.where('sendTime', '<', startTime);
    }

    final results = await query.limit(count).go();

    // 单聊场景需要过滤
    if (groupID == null || groupID.isEmpty) {
      return results.where((msg) {
        final sid = msg['sendID'] as String?;
        final rid = msg['recvID'] as String?;
        return (sid == sendID && rid == recvID) || (sid == recvID && rid == sendID);
      }).toList();
    }

    return results;
  }

  /// 更新消息状态
  Future<void> updateMessageStatus(String clientMsgID, int status) async {
    await db
        .update(DbTableName.localChatLog, {'status': status})
        .where('clientMsgID', '=', clientMsgID)
        .go();
  }

  /// 更新消息（通用）
  Future<void> updateMessage(String clientMsgID, Map<String, dynamic> data) async {
    await db.update(DbTableName.localChatLog, data).where('clientMsgID', '=', clientMsgID).go();
  }

  /// 删除消息
  Future<void> deleteMessage(String clientMsgID) async {
    await db.delete(DbTableName.localChatLog).where('clientMsgID', '=', clientMsgID).go();
  }

  /// 删除会话所有消息
  Future<void> deleteConversationAllMessages({
    String? groupID,
    String? sendID,
    String? recvID,
    int? sessionType,
  }) async {
    if (groupID != null && groupID.isNotEmpty) {
      await db.delete(DbTableName.localChatLog).where('groupID', '=', groupID).go();
    } else if (sessionType != null) {
      // 单聊删除比较复杂，需要全量过滤
      final all = await db
          .query(DbTableName.localChatLog)
          .where('sessionType', '=', sessionType)
          .go();
      for (final msg in all) {
        final sid = msg['sendID'] as String?;
        final rid = msg['recvID'] as String?;
        if ((sid == sendID && rid == recvID) || (sid == recvID && rid == sendID)) {
          final cid = msg['clientMsgID'] as String?;
          if (cid != null) {
            await deleteMessage(cid);
          }
        }
      }
    }
  }

  /// 删除所有本地消息
  Future<void> deleteAllMessages() async {
    final all = await db.query(DbTableName.localChatLog).go();
    for (final msg in all) {
      final cid = msg['clientMsgID'] as String?;
      if (cid != null) {
        await db.delete(DbTableName.localChatLog).where('clientMsgID', '=', cid).go();
      }
    }
  }

  /// 搜索本地消息
  Future<List<Map<String, dynamic>>> searchMessages({
    String? conversationID,
    String? keyword,
    List<int>? messageTypes,
    int? startTime,
    int? endTime,
    int offset = 0,
    int count = 40,
  }) async {
    final all = await db.query(DbTableName.localChatLog).go();
    var filtered = all.where((_) => true);

    if (keyword != null && keyword.isNotEmpty) {
      final lowerKeyword = keyword.toLowerCase();
      filtered = filtered.where((msg) {
        final content = (msg['content'] as String?)?.toLowerCase() ?? '';
        return content.contains(lowerKeyword);
      });
    }

    if (messageTypes != null && messageTypes.isNotEmpty) {
      filtered = filtered.where((msg) {
        final ct = msg['contentType'] as int?;
        return ct != null && messageTypes.contains(ct);
      });
    }

    if (startTime != null && startTime > 0) {
      filtered = filtered.where((msg) {
        final st = msg['sendTime'] as int? ?? 0;
        return st >= startTime;
      });
    }

    if (endTime != null && endTime > 0) {
      filtered = filtered.where((msg) {
        final st = msg['sendTime'] as int? ?? 0;
        return st <= endTime;
      });
    }

    return filtered.skip(offset).take(count).toList();
  }

  /// 标记消息已读
  Future<void> markMessageAsRead(String clientMsgID) async {
    await db
        .update(DbTableName.localChatLog, {
          'isRead': true,
          'hasReadTime': DateTime.now().millisecondsSinceEpoch,
        })
        .where('clientMsgID', '=', clientMsgID)
        .go();
  }

  /// 批量标记消息已读
  Future<void> markMessagesAsRead(List<String> clientMsgIDs) async {
    final now = DateTime.now().millisecondsSinceEpoch;
    for (final id in clientMsgIDs) {
      await db
          .update(DbTableName.localChatLog, {'isRead': true, 'hasReadTime': now})
          .where('clientMsgID', '=', id)
          .go();
    }
  }

